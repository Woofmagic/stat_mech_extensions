Cell[CellGroupData[{
Cell["On the Law of Mass-Action for Modeling:", "Title",
 CellChangeTimes->{{3.984692455691743*^9, 
  3.984692464391869*^9}},ExpressionUUID->"34bbdb7d-171f-4ce4-8d7d-\
c088489b6faa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"k1", "=", "0.4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k2", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k3", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k4", "=", "0.25"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k5", "=", "0.02"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k6", "=", "0.5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9846925227929583`*^9, 3.984692548463932*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"e057402e-5e8c-4b94-adc9-94df8df13c68"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"odeSystem", "=", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"k1", "-", 
        RowBox[{"k2", " ", 
         RowBox[{"x", "[", "t", "]"}]}], "-", 
        RowBox[{"k3", " ", 
         RowBox[{"x", "[", "t", "]"}], " ", 
         RowBox[{"z", "[", "t", "]"}]}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "1"}], ",", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"k3", " ", 
         RowBox[{"x", "[", "t", "]"}], 
         RowBox[{"z", "[", "t", "]"}]}], "-", 
        RowBox[{"k5", " ", 
         RowBox[{"z", "[", "t", "]"}]}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "==", "1"}], ",", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{
        RowBox[{"z", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "k3"}], " ", 
         RowBox[{"x", "[", "t", "]"}], " ", 
         RowBox[{"z", "[", "t", "]"}]}], "+", 
        RowBox[{"k4", " ", 
         RowBox[{"y", "[", "t", "]"}]}], " ", "-", 
        RowBox[{"k6", " ", 
         RowBox[{"z", "[", "t", "]"}]}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"z", "[", "0", "]"}], "==", "1"}]}], "\[IndentingNewLine]", 
     "}"}]}], ";"}], "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.98469244414472*^9, 3.9846924506300917`*^9}, {
  3.984692502600667*^9, 3.984692521650538*^9}, {3.9846925561042147`*^9, 
  3.984692642386848*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"5151dcc1-45d4-4d7c-bcb3-31e1f7d900e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"odeSystemTimeEvolution", "=", 
   RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
    RowBox[{"odeSystem", ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"put", " ", "your", " ", "dynamical", " ", "variables", " ", 
       RowBox[{"here", "!"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "50"}], "}"}]}], " ", 
    RowBox[{"(*", " ", 
     RowBox[{"total", " ", "timesteps", " ", 
      RowBox[{"here", "!"}]}], " ", "*)"}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.984692627149838*^9, 3.984692689472208*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"0cbe1d3f-b21c-4afb-85e8-fca9048dc76b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], ",", 
       RowBox[{"y", "[", "t", "]"}], ",", 
       RowBox[{"z", "[", "t", "]"}]}], "}"}], "/.", " ", 
     "odeSystemTimeEvolution"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "50"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", "Blue", ",", "Green"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x(t)\>\"", ",", "\"\<y(t)\>\"", ",", "\"\<z(t)\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", "\"\<Concentration\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "->", "\"\<HBV Dynamics\>\""}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
