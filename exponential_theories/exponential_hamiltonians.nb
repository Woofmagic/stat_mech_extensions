Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LightconeHamiltonianThreeSpatialDimensions", "=", 
  RowBox[{"Series", "[", "\[IndentingNewLine]", 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox["pz", "2"], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["px", "2"], "+", 
          SuperscriptBox["py", "2"], "+", 
          SuperscriptBox["m", "2"]}], 
         SuperscriptBox["pz", "2"]], "+", "1"}], ")"}]}]], ",", 
    RowBox[{"{", 
     RowBox[{"pz", ",", "\[Infinity]", ",", "2"}], "}"}]}], 
