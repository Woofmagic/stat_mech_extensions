 CellLabel->"In[3]:=",ExpressionUUID->"223a2bca-3e80-4ceb-9914-23ce204d8faf"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"pz", "+", 
   FractionBox[
    RowBox[{
     SuperscriptBox["m", "2"], "+", 
     SuperscriptBox["px", "2"], "+", 
     SuperscriptBox["py", "2"]}], 
    RowBox[{"2", " ", "pz"}]], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", 
      FractionBox["1", "pz"], "]"}], "3"],
    SeriesData[$CellContext`pz, 
     DirectedInfinity[1], {}, -1, 3, 1],
    Editable->False]}],
  SeriesData[$CellContext`pz, 
   DirectedInfinity[1], {
   1, 0, Rational[
     1, 2] ($CellContext`m^2 + $CellContext`px^2 + $CellContext`py^2)}, -1, 3,
    1],
  Editable->False]], "Output",
 CellChangeTimes->{{3.992100911336915*^9, 3.992100955549955*^9}, 
