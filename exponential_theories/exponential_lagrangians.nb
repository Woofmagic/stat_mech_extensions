Cell[TextData[{
 "You can see it\[CloseCurlyQuote]s the wrong rest mass: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", " ", 
    RowBox[{
     SuperscriptBox["c", "2"], "/", "2"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7201efc9-6667-4f62-8213-23c22e960105"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", " ", 
    SuperscriptBox["c", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "179c2cd9-e00b-4e6b-8d6c-e950e4ea5f16"],
 ". But, again, it\[CloseCurlyQuote]s a constant term in the Lagrangian, and \
doesn\[CloseCurlyQuote]t contribute to the nonrelativistic dynamics."
}], "Text",
 CellChangeTimes->{{3.992217288634535*^9, 
  3.992217323972155*^9}},ExpressionUUID->"72fd1161-5031-4d9d-b118-\
b904bb51d8b6"]
}, Open  ]]
}, Open  ]],

