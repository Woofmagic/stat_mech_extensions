Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RelativisticGeneralizedVelocity", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"p", "==", "RelativisticConjugateMomentum"}], ",", "xdot"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.992218112426402*^9, 3.992218136648999*^9}, 
