  RowBox[{"ExoticRelativisticHamiltonian", ",", 
   RowBox[{"{", 
    RowBox[{"p", ",", "0", ",", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[127]:=",ExpressionUUID->"02be4e9b-5107-4473-971a-73cd66cfb2f8"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["c", "2"], " ", "m"}], "+", 
   FractionBox[
    RowBox[{
     RowBox[{"Abs", "[", "p", "]"}], " ", "p"}], "m"], "-", 
   FractionBox[
    SuperscriptBox["p", "2"], 
    RowBox[{"2", " ", "m"}]], "+", 
