Cell[CellGroupData[{

Cell["(#4.2.3): Generate the Hamiltonian:", "Subsection",
 CellChangeTimes->{{3.992218366469326*^9, 
  3.992218375238962*^9}},ExpressionUUID->"f12dc8b7-6095-4ace-807d-\
5153954dee83"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExoticRelativisticHamiltonian", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"p", " ", "xdot"}], "-", "ExoticRelativisticLagrangian"}], 
     ")"}], "/.", " ", 
    RowBox[{"xdot", "->", "ExoticRelativisticGeneralizedVelocity"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9922182994888353`*^9, 3.992218308622753*^9}, {
  3.992218653011321*^9, 3.99221865921106*^9}, {3.9922188458172617`*^9, 
  3.9922188458878717`*^9}, {3.992219070186714*^9, 3.9922190736214*^9}, {
  3.992219212602255*^9, 3.992219219123383*^9}, {3.992219254389306*^9, 
  3.992219255070107*^9}},
 CellLabel->
  "In[108]:=",ExpressionUUID->"944fa3ef-23a3-4f34-82e7-b1c8284549f9"],

Cell[BoxData[
 RowBox[{"c", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"c", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       FractionBox["1", "2"], " ", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox["p", "2"], 
          RowBox[{
           SuperscriptBox["c", "2"], " ", 
           SuperscriptBox["m", "2"]}]]}], "]"}]}]], " ", "m"}], "+", 
    RowBox[{"p", " ", 
     SqrtBox[
      RowBox[{"-", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox["p", "2"], 
          RowBox[{
           SuperscriptBox["c", "2"], " ", 
           SuperscriptBox["m", "2"]}]]}], "]"}]}]]}]}], ")"}]}]], "Output",
 CellChangeTimes->{
  3.992218664626478*^9, 3.992218786106307*^9, 3.992218848095931*^9, {
   3.992219074250842*^9, 3.992219078441101*^9}, 3.9922191838365726`*^9, {
   3.992219250142111*^9, 3.992219255547374*^9}},
 CellLabel->
  "Out[108]=",ExpressionUUID->"780fa4c7-ca91-46dc-bc6b-b041421effff"]
}, Open  ]]
}, Open  ]],

