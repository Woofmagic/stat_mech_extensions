0e5c6dc97e1d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RelativisticLagrangian", "=", 
  RowBox[{
   RowBox[{"-", "m"}], " ", 
   SuperscriptBox["c", "2"], " ", 
   SqrtBox[
    RowBox[{"1", "-", 
     FractionBox[
