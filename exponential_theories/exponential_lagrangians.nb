Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"xdot", "\[Rule]", 
     TemplateBox[{
       FractionBox[
        RowBox[{"c", " ", "p"}], 
        SqrtBox[
         RowBox[{
           RowBox[{
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["m", "2"]}], "+", 
           SuperscriptBox["p", "2"]}]]], 
       RowBox[{
         RowBox[{"\[Beta]", ">", "0"}], "&&", 
         RowBox[{"c", ">", "0"}], "&&", 
         RowBox[{"m", ">", "0"}], "&&", 
         RowBox[{"p", "\[LessEqual]", "0"}]}]},
      "ConditionalExpression"]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"xdot", "\[Rule]", 
     TemplateBox[{
       FractionBox[
        RowBox[{"c", " ", "p"}], 
        SqrtBox[
         RowBox[{
           RowBox[{
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["m", "2"]}], "+", 
           SuperscriptBox["p", "2"]}]]], 
       RowBox[{
         RowBox[{"\[Beta]", ">", "0"}], "&&", 
         RowBox[{"c", ">", "0"}], "&&", 
         RowBox[{"m", ">", "0"}], "&&", 
         RowBox[{"p", ">", "0"}]}]},
      "ConditionalExpression"]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.992218321113078*^9, 3.992218378759685*^9, 
  3.992218663935143*^9, 3.9922187858409157`*^9, 3.9922188479474707`*^9, 
  3.992219183705029*^9, 3.992219250004756*^9},
 CellLabel->
