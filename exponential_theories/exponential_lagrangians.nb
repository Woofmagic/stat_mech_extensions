Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"c", " ", 
    SqrtBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["c", "2"], " ", 
       SuperscriptBox["m", "2"]}], "+", 
      SuperscriptBox["p", "2"]}]]}], ",", 
