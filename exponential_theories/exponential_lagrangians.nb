Cell[CellGroupData[{

Cell["(#4.2.2.3): Verify that the Algebra is right:", "Subsubsection",
 CellChangeTimes->{{3.992218729634783*^9, 
  3.992218739661051*^9}},ExpressionUUID->"7b526870-d25b-4ada-8583-\
703a2e13147b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"ExoticRelativisticConjugateMomentum", "/.", 
   RowBox[{"xdot", "->", "ExoticRelativisticGeneralizedVelocity"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.992218744900587*^9, 3.9922187834781103`*^9}, {
  3.992218843933179*^9, 3.992218844017704*^9}, {3.99221888128683*^9, 
  3.9922188883784857`*^9}, {3.992218995668745*^9, 3.992218997248045*^9}},
 CellLabel->
  "In[106]:=",ExpressionUUID->"d1441441-ac20-40e1-a5ed-3afef89e33ba"],

Cell[BoxData[
 RowBox[{"c", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"-", 
      FractionBox[
       SuperscriptBox["p", "2"], 
       RowBox[{
        SuperscriptBox["c", "2"], " ", 
        SuperscriptBox["m", "2"]}]]}], "]"}]}]], " ", "m", " ", 
  SqrtBox[
   RowBox[{"-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"-", 
      FractionBox[
       SuperscriptBox["p", "2"], 
       RowBox[{
        SuperscriptBox["c", "2"], " ", 
        SuperscriptBox["m", "2"]}]]}], "]"}]}]]}]], "Output",
 CellChangeTimes->{{3.9922187454151363`*^9, 3.992218786084758*^9}, 
