Cell[CellGroupData[{

Cell["(#4.2.2.2): Rely on Algebra here:", "Subsubsection",
 CellChangeTimes->{{3.992218700025447*^9, 
  3.992218709000924*^9}},ExpressionUUID->"ef41445f-1756-4936-91f2-\
78cdbd9d81e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExoticRelativisticGeneralizedVelocity", "=", 
  SqrtBox[
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["c", "2"]}], 
    RowBox[{"ProductLog", "[", 
     RowBox[{"0", ",", 
      FractionBox[
       RowBox[{"-", 
        SuperscriptBox["p", "2"]}], 
       RowBox[{
        SuperscriptBox["m", "2"], 
        SuperscriptBox["c", "2"]}]]}], "]"}]}]]}]], "Input",
 CellChangeTimes->{{3.9922186224767723`*^9, 3.992218639217482*^9}, {
  3.992218763216318*^9, 3.9922187640513363`*^9}, {3.992218873853134*^9, 
  3.9922188740693293`*^9}, {3.992219009576789*^9, 3.9922190188794537`*^9}, {
  3.9922190525333233`*^9, 3.992219061872697*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"a8cd2527-7458-475d-9bf1-5a263abf63ef"],

Cell[BoxData[
 SqrtBox[
  RowBox[{
   RowBox[{"-", 
    SuperscriptBox["c", "2"]}], " ", 
   RowBox[{"ProductLog", "[", 
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["p", "2"], 
      RowBox[{
       SuperscriptBox["c", "2"], " ", 
       SuperscriptBox["m", "2"]}]]}], "]"}]}]]], "Output",
