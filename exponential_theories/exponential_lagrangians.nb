Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["c", "2"], " ", "m"}], "+", 
   FractionBox[
    SuperscriptBox["p", "2"], 
    RowBox[{"2", " ", "m"}]], "-", 
   FractionBox[
    SuperscriptBox["p", "4"], 
    RowBox[{"8", " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", 
       SuperscriptBox["m", "3"]}], ")"}]}]], "+", 
   FractionBox[
    SuperscriptBox["p", "6"], 
    RowBox[{"16", " ", 
     SuperscriptBox["c", "4"], " ", 
     SuperscriptBox["m", "5"]}]], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "p", "]"}], "7"],
    SeriesData[$CellContext`p, 0, {}, 0, 7, 1],
    Editable->False]}],
  SeriesData[$CellContext`p, 
   0, {$CellContext`c^2 $CellContext`m, 0, Rational[1, 2]/$CellContext`m, 0, 
    Rational[-1, 8] $CellContext`c^(-2) $CellContext`m^(-3), 0, 
    Rational[1, 16] $CellContext`c^(-4) $CellContext`m^(-5)}, 0, 7, 1],
  Editable->False]], "Output",
