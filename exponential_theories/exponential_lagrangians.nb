    RowBox[{
     RowBox[{"Abs", "[", "p", "]"}], " ", 
     SuperscriptBox["p", "3"]}], 
    RowBox[{"2", " ", 
     SuperscriptBox["c", "2"], " ", 
     SuperscriptBox["m", "3"]}]], "-", 
   FractionBox[
    RowBox[{"3", " ", 
     SuperscriptBox["p", "4"]}], 
    RowBox[{"8", " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", 
       SuperscriptBox["m", "3"]}], ")"}]}]], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "p", "]"}], "5"],
    SeriesData[$CellContext`p, 0, {}, 0, 5, 1],
    Editable->False]}],
  SeriesData[$CellContext`p, 
   0, {$CellContext`c^2 $CellContext`m, $CellContext`m^(-1) 
    Abs[$CellContext`p], Rational[-1, 2]/$CellContext`m, 
    Rational[1, 2] $CellContext`c^(-2) $CellContext`m^(-3) 
    Abs[$CellContext`p], 
    Rational[-3, 8] $CellContext`c^(-2) $CellContext`m^(-3)}, 0, 5, 1],
  Editable->False]], "Output",
 CellChangeTimes->{3.99221953061196*^9, 3.9922196222192793`*^9},
 CellLabel->
