Cell[CellGroupData[{

Cell["\<\
(#2.1.2.1): Seeing how many Solutions are found for the Implicit Equation:\
\>", "Subsubsection",
 CellChangeTimes->{{3.979580799195891*^9, 
  3.979580813718585*^9}},ExpressionUUID->"d5a3613b-0054-40f5-9ad2-\
57cf1cf7bb82"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"ConstE", "==", 
      RowBox[{"SISHamiltonian", "[", 
       RowBox[{"q", ",", "p"}], "]"}]}], ",", "p"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Assumptions", "->", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[Infinity]"}], "<", "q", "<", "\[Infinity]"}], "&&", 
     RowBox[{
      RowBox[{"-", "\[Infinity]"}], "<", "p", "<", "\[Infinity]"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"ConstE", "\[Element]", "Reals"}], "&&", "\[IndentingNewLine]", 
     RowBox[{"\[Beta]Tilde", "\[Element]", "Reals"}], "&&", 
     RowBox[{"\[Gamma]", "\[Element]", "Reals"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9787164165407143`*^9, 3.978716517425126*^9}, {
   3.978716598636434*^9, 3.978716626713106*^9}, {3.9787857473731422`*^9, 
   3.978785747526458*^9}, {3.9787866533566017`*^9, 3.978786664561541*^9}, {
   3.979580739096911*^9, 3.9795807778709793`*^9}, {3.987938444883279*^9, 
   3.987938449860599*^9}, 3.9884782833089933`*^9, {3.988478924661757*^9, 
   3.98847894196585*^9}},
 CellLabel->"In[67]:=",ExpressionUUID->"1727c2a8-04b5-4d29-b1a8-399be4c6b359"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SISHamiltonian", "[", 
    RowBox[{"q", ",", "p"}], "]"}], "/.", 
   RowBox[{"p", "->", 
    RowBox[{"Log", "[", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"q", " ", "\[Beta]Tilde"}]], "-", 
