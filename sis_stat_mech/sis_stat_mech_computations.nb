Cell["(#1.1.2): Exponentiate it:", "Subsection",
 CellChangeTimes->{{3.978627422029333*^9, 3.9786274352895613`*^9}, {
  3.981128296964848*^9, 3.98112830509867*^9}, {3.9884783334794083`*^9, 
