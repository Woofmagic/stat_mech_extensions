62692fe1f01b"],

Cell["\<\
For initial conditions of S(0) = 499 and I(0) = 1, \[Beta] = 0.001, \[Gamma] \
= 0.1, N = 1, we need to find the initial conditions for q and p:\
\>", "Text",
 CellChangeTimes->{{3.979580582482852*^9, 3.979580607437624*^9}, {
  3.988478439860714*^9, 3.9884784710675793`*^9}, {3.9884785872822113`*^9, 
  3.988478599115786*^9}, {3.988478697176351*^9, 
  3.988478705752565*^9}},ExpressionUUID->"5069d0de-ba45-441d-9a04-\
c18059eb4d7a"],

Cell[BoxData[
 RowBox[{"0.0001", "/", "1", " ", 
  RowBox[{"(*", " ", 
   RowBox[{"this", " ", "is", " ", 
    RowBox[{"\[Beta]", "/", "N"}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.988478474426691*^9, 3.9884785331822357`*^9}, {
   3.98847860729097*^9, 3.988478621595402*^9}, 3.9884786627531223`*^9, {
   3.988478708391992*^9, 3.9884787169276333`*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"61fb3a3e-affc-4810-85ff-05df28e06751"],

Cell["this is the initial condition for q(S):", "Text",
 CellChangeTimes->{{3.988478721164575*^9, 
  3.9884787306636*^9}},ExpressionUUID->"a83a3e0a-c716-48ae-b779-29bd9eb4a616"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox["1", "\[Beta]Tilde"], 
     RowBox[{"Log", "[", 
      RowBox[{
       RowBox[{"\[Beta]Tilde", " ", "Susceptible"}], "-", "\[Gamma]"}], 
      "]"}]}], "/.", 
    RowBox[{"Susceptible", "->", ".999"}]}], "/.", 
   RowBox[{"\[Beta]Tilde", "->", 
    RowBox[{"(", 
     RowBox[{"0.0001", "/", "1"}], ")"}]}]}], "/.", 
  RowBox[{"\[Gamma]", "->", "0.1"}]}]], "Input",
 CellChangeTimes->{{3.988478625518302*^9, 3.988478667403714*^9}, {
  3.9884787555902653`*^9, 3.988478785194386*^9}},
 CellLabel->"In[61]:=",ExpressionUUID->"a52699c0-6328-46ef-a3d8-ed47df32b613"],

Cell["this is the initial condition for p(I):", "Text",
 CellChangeTimes->{{3.988478732958749*^9, 
  3.988478744444934*^9}},ExpressionUUID->"6901d3d6-1485-4db1-b690-\
5bb88de78100"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Log", "[", "Infected", "]"}], "/.", 
  RowBox[{"Infected", "->", ".001"}]}]], "Input",
 CellChangeTimes->{{3.9884785189408092`*^9, 3.9884785363004227`*^9}, {
  3.9884787872242327`*^9, 3.9884787898322973`*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"8cfc8348-54c7-4cef-893f-10a74ce807d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SISHamiltonian", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "23035.84592327129`"}], "+", 
      RowBox[{"31415.926535897932`", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{"-", "6.907755278982137"}]}], "]"}], "/.", 
   RowBox[{"\[Beta]Tilde", "->", 
    RowBox[{"(", 
     RowBox[{"0.0001", "/", "1"}], ")"}]}]}], "/.", 
  RowBox[{"\[Gamma]", "->", "0.1"}]}]], "Input",
 CellChangeTimes->{{3.978788883261161*^9, 3.978788885528715*^9}, {
   3.978789087532275*^9, 3.978789106563046*^9}, 3.979580367100677*^9, {
   3.979580411411729*^9, 3.97958042305995*^9}, 3.988478283288795*^9, {
   3.988478365965005*^9, 3.988478367806014*^9}, {3.988478541892551*^9, 
   3.9884785420555487`*^9}, {3.9884787953827953`*^9, 3.988478805861945*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"57010c7d-d7a7-4021-8710-7e2d665b7d00"]
}, Open  ]],

