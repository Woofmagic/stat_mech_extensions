Cell[CellGroupData[{

Cell["(#1.1.1): Defining the Hamiltonian:", "Subsection",
 CellChangeTimes->{{3.97862744919598*^9, 
  3.978627453528882*^9}},ExpressionUUID->"aaad9fd2-23d5-4e9f-8ae7-\
d1dcb8dcdd3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SISHamiltonian", "[", 
    RowBox[{"q_", ",", "p_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", "p", "]"}], "+", 
    FractionBox[
     RowBox[{"Exp", "[", 
      RowBox[{"\[Beta]Tilde", " ", "q"}], "]"}], "\[Beta]Tilde"], "+", 
    FractionBox["\[Gamma]", "\[Beta]Tilde"]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9786273818456984`*^9, 3.97862741195427*^9}, {
  3.988478276234*^9, 3.988478329368891*^9}, {3.988478570346118*^9, 
  3.9884785782114697`*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"290e2934-a1ff-48d0-bb0a-4f8faa772360"]
}, Open  ]],

