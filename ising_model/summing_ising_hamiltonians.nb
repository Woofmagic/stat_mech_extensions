Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CalculateVarianceEnergy", "[", "PartitionFunction_", "]"}], ":=", 
   
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"Log", "[", "PartitionFunction", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Beta]", ",", "2"}], "}"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9503656034373207`*^9, 3.950365616777961*^9}, 
   3.950365725315114*^9, 3.950365822842842*^9},
 CellLabel->"In[16]:=",ExpressionUUID->"698166d4-023c-4f29-a34c-acc6110e49c4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CalculateFreeEnergy", "[", "PartitionFunction_", "]"}], ":=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"Log", "[", "PartitionFunction", "]"}], "\[Beta]"]}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9503657156902847`*^9, 3.950365718745912*^9}, {
  3.950365799999802*^9, 3.950365822220727*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"6f1bcc92-0fbb-488b-bf66-04e3bc1cdf62"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CalculateEntropy", "[", "PartitionFunction_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Log", "[", "PartitionFunction", "]"}], "+", 
    RowBox[{"\[Beta]", " ", 
     RowBox[{"CalculateAverageEnergy", "[", "PartitionFunction", "]"}]}]}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9839628499520903`*^9, 3.9839628537517557`*^9}, {
  3.983962891874235*^9, 3.983962905805159*^9}, {3.983962950838881*^9, 
