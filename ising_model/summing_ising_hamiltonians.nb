Notebook[{

Cell[CellGroupData[{
Cell["Exploring Nontrivial Ising Spin Topologies", "Title",
 CellChangeTimes->{{3.9503638936516953`*^9, 
  3.950363912871625*^9}},ExpressionUUID->"bccf83be-c4ff-45a5-92d9-\
4e00f5b75d4b"],

Cell["\<\
Here, we attempt to understand the statistical mechanics of Ising-spin models \
on Cayley Graph topologies.\
\>", "Text",
 CellChangeTimes->{{3.950363915797248*^9, 3.950363938989613*^9}, {
  3.983969811432548*^9, 
  3.983969825966373*^9}},ExpressionUUID->"e7dd95bd-3f52-4a07-9d66-\
e7db0427c0bc"],

Cell[CellGroupData[{

Cell["Section 1 | Coding the Partition Function:", "Chapter",
 CellChangeTimes->{{3.950363941491639*^9, 3.95036395517485*^9}, 
   3.9503640507959146`*^9},ExpressionUUID->"24eedb75-6e50-4490-98b2-\
76852e979078"],

Cell["Section 1.1 | The Partition Function:", "Subtitle",
 CellChangeTimes->{{3.950364054977069*^9, 3.950364057939424*^9}, {
  3.950364098023316*^9, 
  3.9503641148598022`*^9}},ExpressionUUID->"a3b4dcf5-1c28-4704-a25f-\
68a0475dd6d3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PartitionFunctionForIsingSpins", "[", 
    RowBox[{"Hamiltonian_", ",", "n_Integer", ",", 
     RowBox[{"OptionsPattern", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<Verbose\>\"", "->", "False"}], "}"}], "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "SymbolicSpinVariables", ",", "PartitionFunctionSymbolicForm", ",", 
       "PartitionFunctionNumerical", ",", "MicroscopicConfigurations", ",", 
       RowBox[{"i", "=", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Define", " ", "the", " ", "spins", " ", "as", " ", 
       RowBox[{"s", "[", "i", "]"}], " ", "symbols"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SymbolicSpinVariables", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"s", "[", "i", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Construct", " ", "symbolic", " ", "Boltzmann", " ", "factor"}], 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"PartitionFunctionSymbolicForm", "=", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "\[Beta]"}], "*", "Hamiltonian"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "\"\<Verbose\>\"", "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<> Symbolic partition function: Z = \>\"", ",", 
           StyleBox["PartitionFunctionSymbolicForm",
            FontWeight->"Bold"]}], "]"}], ";"}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Generate", " ", "all", " ", "spin", " ", 
        RowBox[{"configurations", ":", 
         RowBox[{
          RowBox[{"each", " ", 
           RowBox[{"s", "[", "i", "]"}]}], "\[Element]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "1"}], "}"}]}]}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"MicroscopicConfigurations", "=", 
       RowBox[{"Tuples", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "n"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Sum", " ", "the", " ", "Boltzmann", " ", "factor", " ", "over", " ", 
        "all", " ", "configurations"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"PartitionFunctionNumerical", "=", 
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"i", "++"}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"OptionValue", "[", "\"\<Verbose\>\"", "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Print", "[", 
               RowBox[{
               "\"\<> Summing configuration #\>\"", ",", "i", ",", 
                "\"\<: \>\"", ",", "#"}], "]"}]}], "\[IndentingNewLine]", 
             "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"PartitionFunctionSymbolicForm", "/.", " ", 
             RowBox[{"Thread", "[", 
              RowBox[{"SymbolicSpinVariables", "->", "#"}], "]"}]}]}], ")"}], 
          "&"}], "/@", 
         StyleBox["MicroscopicConfigurations",
          FontWeight->"Bold"]}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "PartitionFunctionNumerical"}]}], 
    "\[IndentingNewLine]", "]"}]}], "\n"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9534609675333767`*^9, 3.953461011886445*^9}, {
  3.953461055566082*^9, 3.953461056181308*^9}, {3.953461142720539*^9, 
  3.9534611564994593`*^9}, {3.953462074203267*^9, 3.9534622124644003`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"b6c306cd-6d1c-40a1-ad2f-c7d9ef7ebc1d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CalculateAverageEnergy", "[", "PartitionFunction_", "]"}], ":=", 
   RowBox[{"-", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Log", "[", "PartitionFunction", "]"}], ",", "\[Beta]"}], 
     "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.950364487036208*^9, {3.9503654142224503`*^9, 3.950365482901216*^9}, {
