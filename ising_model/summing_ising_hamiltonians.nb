Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FreeECayleyGraphS3", "=", 
  RowBox[{
   RowBox[{"CalculateFreeEnergy", "[", "ZCayleyGraphS3", "]"}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{
  3.954851305930068*^9, {3.983959402937296*^9, 3.983959416362104*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"30de66f4-d648-48d4-b012-f8facdb408c6"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"Log", "[", 
    RowBox[{
     RowBox[{"-", "32"}], " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", " ", "J", " ", "\[Beta]"}]], " ", 
     SuperscriptBox[
      RowBox[{"Cosh", "[", 
       RowBox[{"J", " ", "\[Beta]"}], "]"}], "3"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "3"}], "+", 
       RowBox[{"3", " ", 
        RowBox[{"Cosh", "[", 
         RowBox[{"2", " ", "J", " ", "\[Beta]"}], "]"}]}], "-", 
       RowBox[{"2", " ", 
        RowBox[{"Cosh", "[", 
         RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}], "+", 
       RowBox[{"Sinh", "[", 
        RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}], ")"}]}], "]"}], 
   "\[Beta]"]}]], "Output",
 CellChangeTimes->{3.9548513069701967`*^9, 3.954856133348546*^9, 
  3.9548562640563583`*^9, 3.983913675555018*^9, 3.983959419506152*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"a8f1805b-c8ce-4919-9693-633f32166d2f"]
}, Open  ]],

