Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SCayleyGraphS3", "=", 
  RowBox[{
   RowBox[{"CalculateEntropy", "[", "ZCayleyGraphS3", "]"}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.983963001434647*^9, 3.983963006762518*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"04b45950-9de2-4f40-8ba2-7214c8c11687"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "2"}], " ", "J", " ", "\[Beta]"}], "+", 
  RowBox[{"Log", "[", 
   RowBox[{
    RowBox[{"-", "32"}], " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "J", " ", "\[Beta]"}]], " ", 
    SuperscriptBox[
     RowBox[{"Cosh", "[", 
      RowBox[{"J", " ", "\[Beta]"}], "]"}], "3"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "+", 
      RowBox[{"3", " ", 
       RowBox[{"Cosh", "[", 
        RowBox[{"2", " ", "J", " ", "\[Beta]"}], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Cosh", "[", 
        RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}], "+", 
      RowBox[{"Sinh", "[", 
       RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}], ")"}]}], "]"}], "-", 
  
  FractionBox[
   RowBox[{"2", " ", "J", " ", "\[Beta]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       RowBox[{"Cosh", "[", 
        RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}], "+", 
      RowBox[{"3", " ", 
       RowBox[{"Sinh", "[", 
        RowBox[{"2", " ", "J", " ", "\[Beta]"}], "]"}]}], "-", 
      RowBox[{"4", " ", 
       RowBox[{"Sinh", "[", 
        RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}]}], ")"}]}], 
   RowBox[{
    RowBox[{"-", "3"}], "+", 
    RowBox[{"3", " ", 
     RowBox[{"Cosh", "[", 
      RowBox[{"2", " ", "J", " ", "\[Beta]"}], "]"}]}], "-", 
    RowBox[{"2", " ", 
     RowBox[{"Cosh", "[", 
      RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}], "+", 
    RowBox[{"Sinh", "[", 
     RowBox[{"4", " ", "J", " ", "\[Beta]"}], "]"}]}]], "-", 
  RowBox[{"3", " ", "J", " ", "\[Beta]", " ", 
   RowBox[{"Tanh", "[", 
    RowBox[{"J", " ", "\[Beta]"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.983963008821443*^9},
 CellLabel->"Out[63]=",ExpressionUUID->"43bf3395-3395-43af-8773-52ff29cc294d"]
}, Open  ]],

