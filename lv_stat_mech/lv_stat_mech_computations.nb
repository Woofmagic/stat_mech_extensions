Cell[CellGroupData[{

Cell["\<\
(#2.1.3.5): We are going to try numerical integration to compare!\
\>", "Subsubsection",
 CellChangeTimes->{{3.99080420759336*^9, 3.990804219594679*^9}, {
  3.9917800679456673`*^9, 
  3.991780069004079*^9}},ExpressionUUID->"0dc04f26-ce0a-432d-afd3-\
db33a14d54fc"],

Cell["First of all, what is the numerical integral?", "Text",
 CellChangeTimes->{{3.990804228395883*^9, 
  3.990804233022169*^9}},ExpressionUUID->"59ce264f-0eca-47a7-a6c8-\
4d7dd120e01d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NIntegrate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ProductLog", "[", 
    RowBox[{"0", ",", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"Exp", "[", "q", "]"}], "]"}], ",", "q"}], "]"}]}], "]"}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"q", ",", " ", "5", ",", "6"}], "}"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.990794641953051*^9, 3.9907946579056*^9}, {
  3.990794691572329*^9, 3.990794693865265*^9}, {3.990803672043111*^9, 
