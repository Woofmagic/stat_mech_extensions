Cell[CellGroupData[{

Cell[TextData[{
 "(#3.2): Average Energy, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", "E", "\[RightAngleBracket]"}], "=", 
    RowBox[{"-", 
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", " ", "\[Beta]"}]], 
      RowBox[{"log", "(", "Z", ")"}]}]}]}], TraditionalForm]], "Section",
  ExpressionUUID->"064b35bb-0380-4209-9ce7-9bba5ba022ae"],
 ":"
}], "Section",
