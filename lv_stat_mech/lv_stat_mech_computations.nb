 CellLabel->
  "In[143]:=",ExpressionUUID->"da517f0c-5fe5-4ff7-9322-e991ee228a6d"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "(#2.1.2.4): Test Run Using a Dummy Integrand, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    RowBox[{"dx", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{
         SubscriptBox["W", "0"], "(", "x", ")"}]}], "+", 
       RowBox[{
        SubscriptBox["W", "1"], "(", "x", ")"}]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"e8dac027-3e75-4eaa-a929-e2a375e81560"],
 ":"
}], "Subsubsection",
 CellChangeTimes->{{3.979581213030114*^9, 3.9795812308323393`*^9}, {
  3.9795823317803392`*^9, 3.9795823449005003`*^9}, {3.987938740352964*^9, 
  3.987938746332321*^9}},ExpressionUUID->"f0bbdf0b-34e8-4953-b764-\
d32327fbdad2"],

Cell["Below, x stands for the insane thing in the ProductLog[].", "Text",
 CellChangeTimes->{{3.979581232325411*^9, 
  3.9795812404344397`*^9}},ExpressionUUID->"856e58a4-0d84-42b2-ae1a-\
7a294cb248b3"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Integrate", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"0", ",", "x"}], "]"}]}], "+", 
      RowBox[{"ProductLog", "[", 
       RowBox[{"1", ",", "x"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "a", ",", " ", "b"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"a", ">", "0"}], "&&", 
     RowBox[{"b", ">", "0"}], "&&", 
     RowBox[{"b", ">", "a"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.978789331264576*^9, 3.97878943612733*^9}},
 CellLabel->
  "In[144]:=",ExpressionUUID->"cd4419c4-9c3c-42ff-a3e6-9695aaf48351"]
}, Closed]],

Cell[CellGroupData[{

Cell["(#2.1.2.5): Trying the whole thing:", "Subsubsection",
 CellChangeTimes->{{3.979581375656221*^9, 3.979581381154336*^9}, {
  3.990276833436225*^9, 
  3.990276834997435*^9}},ExpressionUUID->"41053fb2-2693-4c38-9376-\
145d8432d487"],

Cell[BoxData[
 RowBox[{"Integrate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"ProductLog", "[", 
      RowBox[{"0", ",", 
       FractionBox[
