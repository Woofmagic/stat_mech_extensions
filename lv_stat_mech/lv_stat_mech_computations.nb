Cell[CellGroupData[{

Cell["(#X): Keeping the Rotation Angle \[Phi] Open:", "Chapter",
 CellChangeTimes->{{3.988464190090456*^9, 
  3.988464202544304*^9}},ExpressionUUID->"9f25cf82-9d45-4665-96a2-\
9f65d2a4389b"],

Cell[CellGroupData[{

Cell["(#X.1): Transforming to the Hamiltonian:", "Section",
 CellChangeTimes->{{3.988464215354912*^9, 3.9884642457716007`*^9}, 
   3.9884669235886383`*^9},ExpressionUUID->"c686910c-bc54-4906-a75b-\
f5c488601fb8"],

Cell[CellGroupData[{

Cell["(#X.1.1): Original Dynamical Invariant:", "Subsection",
 CellChangeTimes->{{3.988464247292055*^9, 
  3.988464254844431*^9}},ExpressionUUID->"47a5b53b-afb6-45b2-8ef5-\
1dcd2b004e72"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LVDynInvariant", "=", 
   RowBox[{
    RowBox[{"\[Delta]", " ", "x"}], " ", "-", " ", 
    RowBox[{"\[Gamma]", " ", 
     RowBox[{"Log", "[", "x", "]"}]}], "+", 
    RowBox[{"\[Beta]", " ", "y"}], "-", 
    RowBox[{"\[Alpha]", " ", 
     RowBox[{"Log", "[", "y", "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.988464261378422*^9, 3.988464289970059*^9}},
 CellLabel->
  "In[420]:=",ExpressionUUID->"a00d1191-113b-4cdf-8051-d6da832ea609"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#X.1.2): Verifying original coordinate transformation works:\
\>", "Subsection",
 CellChangeTimes->{{3.988464683183737*^9, 
  3.988464693671782*^9}},ExpressionUUID->"169219e8-f13c-43bf-9f3c-\
8922d3a92cd8"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"LVHamiltonian", "[", 
       RowBox[{"q", ",", "p"}], "]"}], "-", "LVDynInvariant"}], "/.", 
     RowBox[{"y", "->", 
      RowBox[{"Exp", "[", "q", "]"}]}]}], "/.", 
    RowBox[{"x", "->", 
     RowBox[{"Exp", "[", "p", "]"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"x", "\[Element]", "Reals"}], "&&", 
     RowBox[{"y", "\[Element]", "Reals"}], "&&", 
     RowBox[{"q", "\[Element]", "Reals"}], "&&", 
     RowBox[{"p", "\[Element]", "Reals"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988464556201309*^9, 3.9884645708597517`*^9}, {
  3.9884646215774593`*^9, 3.9884646789364767`*^9}},
 CellLabel->
  "In[421]:=",ExpressionUUID->"0faa9d44-caa0-452f-9e57-a7a4b55baed6"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "(#X.1.3): Now, do the original transformation for (x, y) and (q, p) was for \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", 
    FractionBox["\[Pi]", "4"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1dff567c-456f-45a4-ae6c-e18d4b2873d6"],
 ":"
}], "Subsection",
 CellChangeTimes->{{3.988464362407053*^9, 3.988464367069214*^9}, {
  3.988464528005765*^9, 3.988464529411337*^9}, {3.988464772310697*^9, 
  3.988464776089492*^9}, {3.9884648607934217`*^9, 3.988464903539596*^9}, {
  3.988465403936051*^9, 3.988465421323827*^9}, {3.988465482573564*^9, 
  3.9884654972623377`*^9}},ExpressionUUID->"a8d425cf-23a9-407b-8566-\
be40a699d541"],

Cell[TextData[{
 "Must understand that we",
 StyleBox[" flipped ",
  FontSlant->"Italic"],
 "the \[OpenCurlyDoubleQuote]chirality\[CloseCurlyDoubleQuote] when we \
assigned q to log(y) and p to log(x), and that\[CloseCurlyQuote]s why we have \
",
 StyleBox["flipped ",
  FontSlant->"Italic"],
 "the order of the logs in this column vector below:"
}], "Text",
 CellChangeTimes->{{3.9884649831328993`*^9, 3.988464988133391*^9}, {
  3.988466460825042*^9, 
  3.9884665127262278`*^9}},ExpressionUUID->"61baa0b7-0798-4cb8-b539-\
e83116b9630f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RotationMatrix", "[", 
    FractionBox["\[Pi]", "4"], "]"}], ".", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Log", "[", "y", "]"}], ",", 
     RowBox[{"Log", "[", "x", "]"}]}], "}"}]}], "//", "MatrixForm"}]], "Input",\

 CellChangeTimes->{{3.988465001446836*^9, 3.988465007970234*^9}, {
  3.9884653945413027`*^9, 3.9884654268058157`*^9}, {3.988465499766926*^9, 
  3.988465506866561*^9}, {3.988465851384623*^9, 3.988465852069067*^9}, {
  3.988466446271558*^9, 3.9884664520960827`*^9}},
 CellLabel->
  "In[422]:=",ExpressionUUID->"ae23ba5b-868b-461b-8d50-a5f5f53b1c4e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#X.1.4): Here is then the arbitrary transformation between (x, y) and (q, p) \
for any \[Phi]:\
\>", "Subsection",
 CellChangeTimes->{{3.988466518438414*^9, 
  3.988466533114871*^9}},ExpressionUUID->"e41d9172-5332-460a-bedb-\
a9f4b9952b43"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RotationMatrix", "[", "\[Phi]", "]"}], ".", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Log", "[", "y", "]"}], ",", 
     RowBox[{"Log", "[", "x", "]"}]}], "}"}]}], "//", "MatrixForm"}]], "Input",\

 CellChangeTimes->{{3.988466637722376*^9, 3.988466640782288*^9}},
 CellLabel->
  "In[423]:=",ExpressionUUID->"7c539aaa-0e99-4389-9645-e091d5fd3e11"],

Cell[BoxData[
 RowBox[{"Solve", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"p", "==", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Log", "[", "x", "]"}]}], "+", 
       RowBox[{
        RowBox[{"Log", "[", "y", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]}], ",", 
     RowBox[{"q", "==", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Log", "[", "y", "]"}]}], "-", 
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988464310645822*^9, 3.988464370693057*^9}, {
  3.9884647776837463`*^9, 3.98846481652215*^9}, {3.988466644937315*^9, 
  3.988466652776167*^9}, {3.9884694081218233`*^9, 3.9884694098272467`*^9}},
 CellLabel->
  "In[424]:=",ExpressionUUID->"75ce3301-d853-475d-8190-3799b29d1ae8"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"LVDynInvariant", "/.", 
     RowBox[{"y", "->", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "p"}], " ", 
           RowBox[{"Csc", "[", "\[Phi]", "]"}]}], "-", 
          RowBox[{"q", " ", 
           RowBox[{"Cot", "[", "\[Phi]", "]"}], " ", 
           RowBox[{"Csc", "[", "\[Phi]", "]"}]}]}], 
         RowBox[{"1", "+", 
          SuperscriptBox[
           RowBox[{"Cot", "[", "\[Phi]", "]"}], "2"]}]]}]]}]}], "/.", 
    RowBox[{"x", "->", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"-", "p"}], " ", 
          RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "+", 
         RowBox[{"q", " ", 
          RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], 
        RowBox[{
         SuperscriptBox[
          RowBox[{"Cos", "[", "\[Phi]", "]"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}]]}]]}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"q", "\[Element]", "Reals"}], "&&", 
     RowBox[{"p", "\[Element]", "Reals"}], "&&", 
     RowBox[{"\[Phi]", "\[Element]", "Reals"}]}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.98846438586121*^9, 3.988464405693465*^9}, 
   3.988464482146572*^9, 3.988464706274599*^9, {3.9884647434259863`*^9, 
   3.9884647584225883`*^9}, {3.988464826416644*^9, 3.988464850673068*^9}, {
   3.988466674080639*^9, 3.988466678848566*^9}, {3.9884671436101227`*^9, 
   3.9884671598654327`*^9}, {3.988469441741371*^9, 3.988469446232704*^9}, {
   3.9884695044287252`*^9, 3.9884695098844423`*^9}},
 CellLabel->
  "In[425]:=",ExpressionUUID->"bf649cd6-1a60-4e3d-a834-029d3be89420"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#X.2): Constructing the Canonical Ensemble Partition Function:\
\>", "Section",
 CellChangeTimes->{{3.98846692613634*^9, 
  3.9884669381024017`*^9}},ExpressionUUID->"fc87a341-5eee-4777-aa21-\
62a8d89a0a80"],

Cell[CellGroupData[{

Cell["(#X.2.1): Arbitrary Angle Hamiltonian:", "Subsection",
 CellChangeTimes->{{3.988466952504928*^9, 
  3.9884669704221992`*^9}},ExpressionUUID->"1996aae0-18ee-49e9-ac81-\
3667260cdd8f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LVRotatedHamiltonian", "[", 
    RowBox[{"q_", ",", "p_", ",", "\[Phi]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"q", " ", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "+", 
       RowBox[{"p", " ", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]], " ", "\[Beta]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"p", " ", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "-", 
       RowBox[{"q", " ", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]], " ", "\[Delta]"}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"q", " ", "\[Alpha]"}], "+", 
       RowBox[{"p", " ", "\[Gamma]"}]}], ")"}], " ", 
     RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "p"}], " ", "\[Alpha]"}], "+", 
       RowBox[{"q", " ", "\[Gamma]"}]}], ")"}], " ", 
     RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.988466975270341*^9, 3.988466990715797*^9}, {
  3.9884672835166397`*^9, 3.9884673110356493`*^9}, {3.988467601924324*^9, 
  3.988467609598295*^9}, {3.988467666411586*^9, 3.9884676665713453`*^9}, {
  3.9884690523228407`*^9, 3.988469056712792*^9}, {3.9884694680622168`*^9, 
  3.988469468282213*^9}},
 CellLabel->
  "In[426]:=",ExpressionUUID->"d3f27d9d-1fd8-4524-8f7d-a4b1a114bf04"],

Cell["\<\
Quickly checking that this generalizes the previous Hamiltonian at \[Phi] = 0;\
\>", "Text",
 CellChangeTimes->{{3.988468793705039*^9, 3.9884688106721354`*^9}, {
  3.9884695388346148`*^9, 
  3.9884695418511257`*^9}},ExpressionUUID->"70b303d0-73e6-4a88-8d5f-\
9ecc8f74db91"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"LVRotatedHamiltonian", "[", 
    RowBox[{"q", ",", "p", ",", "0"}], "]"}], "-", 
   RowBox[{"LVHamiltonian", "[", 
    RowBox[{"q", ",", "p"}], "]"}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.988468813336104*^9, 3.98846884295289*^9}, {
   3.988468880333233*^9, 3.988468880589135*^9}, {3.988469025010684*^9, 
   3.9884690308001957`*^9}, {3.988469067698393*^9, 3.9884690726822033`*^9}, 
   3.9884694774423027`*^9, {3.988469526833106*^9, 3.988469531594081*^9}, 
   3.992104640997998*^9},ExpressionUUID->"02c33181-2bd2-47f3-89ba-\
2fd2676c7703"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#X.2.2): Arbitrary Angle Canonical Ensemble Partition Function:\
\>", "Subsection",
 CellChangeTimes->{{3.988466996156453*^9, 
  3.9884670067084093`*^9}},ExpressionUUID->"340ad141-b984-427d-9923-\
09b8d57e1d2a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LVRotatedZ", "[", "\[Sigma]_", "]"}], ":=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[Sigma]"}], " ", 
     RowBox[{"LVRotatedHamiltonian", "[", 
      RowBox[{"q", ",", "p", ",", "\[Phi]"}], "]"}]}], "]"}]}], 
