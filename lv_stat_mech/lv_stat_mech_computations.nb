       RowBox[{"Exp", "[", "x", "]"}]}], "]"}]}], "]"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"x", "\[Element]", "PositiveReals"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.990799404276458*^9, 3.99079940486287*^9}},
 CellLabel->
  "In[168]:=",ExpressionUUID->"ed1126f9-fe65-4683-bc7f-be6faafad58d"],

