 CellChangeTimes->{{3.9879396754512377`*^9, 
  3.9879396833808737`*^9}},ExpressionUUID->"215e62d6-9ed8-4743-8093-\
2e4a759e987c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"1", " ", 
     SuperscriptBox["\[ExponentialE]", "p"]}], "-", 
    RowBox[{"1", " ", "p"}], "+", 
    RowBox[{"0.01", 
     RowBox[{"Exp", "[", "q", "]"}]}], "-", 
    RowBox[{"0.01", "q"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"q", ",", 
     RowBox[{"-", "20"}], ",", "10"}], "}"}], ",", 
   RowBox[{"{", 
