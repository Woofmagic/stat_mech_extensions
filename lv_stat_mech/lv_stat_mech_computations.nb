Cell[CellGroupData[{

Cell["\<\
(#3.6.1): Quantitative calculation using the standard formula:\
\>", "Subsection",
 CellChangeTimes->{{3.979568992523485*^9, 
  3.979568994296278*^9}},ExpressionUUID->"4af0e0c7-d26e-4ea9-bb32-\
8cebd497503e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LVFreeEnergy", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "\[Theta]"]}], 
    RowBox[{"Log", "[", "LVZIntegral", "]"}]}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.979568995989708*^9, 3.979569034808258*^9}, {
  3.9795696029572067`*^9, 3.979569606398595*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"143d05f9-9dba-4ddd-81b6-db19f85d90ae"],

Cell[BoxData[
 TemplateBox[{
   RowBox[{"-", 
     FractionBox[
      RowBox[{"Log", "[", 
        RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"\[Beta]", " ", "\[Theta]"}], ")"}], 
           RowBox[{
             RowBox[{"-", "\[Alpha]"}], " ", "\[Theta]"}]], " ", 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"\[Delta]", " ", "\[Theta]"}], ")"}], 
           RowBox[{
             RowBox[{"-", "\[Gamma]"}], " ", "\[Theta]"}]], " ", 
          RowBox[{"Gamma", "[", 
            RowBox[{"\[Alpha]", " ", "\[Theta]"}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
            RowBox[{"\[Gamma]", " ", "\[Theta]"}], "]"}]}], "]"}], 
      "\[Theta]"]}], 
   RowBox[{
     RowBox[{"(", 
       RowBox[{
         RowBox[{"\[Alpha]", ">", "0"}], "&&", 
         RowBox[{"\[Beta]", ">", "0"}], "&&", 
         RowBox[{"\[Theta]", ">", "0"}]}], ")"}], "||", 
     RowBox[{"(", 
       RowBox[{
         RowBox[{"\[Alpha]", "<", "0"}], "&&", 
         RowBox[{"\[Beta]", "<", "0"}], "&&", 
         RowBox[{"\[Theta]", "<", "0"}]}], ")"}]}]},
  "ConditionalExpression"]], "Output",
 CellChangeTimes->{{3.9795690106285677`*^9, 3.979569035331616*^9}, {
   3.9795696034011908`*^9, 3.9795696066881933`*^9}, 3.979580176717083*^9, 
   3.979665976350071*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"9d907c5a-9d0e-4b96-ac39-8e9c47e15eb7"]
}, Open  ]]
}, Open  ]],

