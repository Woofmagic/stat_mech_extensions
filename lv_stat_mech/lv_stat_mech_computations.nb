Cell[CellGroupData[{

Cell["(#2.1.2.2): Manually Entering the Solutions We Got:", "Subsubsection",
 CellChangeTimes->{{3.979580820672736*^9, 
  3.9795808349077806`*^9}},ExpressionUUID->"f3efd2f8-af2d-4380-be99-\
0abaad054ffa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pPlus", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "ConstE"}], "+", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"Exp", "[", "q", "]"}]}], "-", 
      RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"0", ",", 
      RowBox[{
       FractionBox["\[Delta]", "\[Gamma]"], 
       RowBox[{"Exp", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"-", "ConstE"}], "+", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"Exp", "[", "q", "]"}]}], "-", 
          RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "]"}]}]}], "]"}]}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pMinus", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "ConstE"}], "+", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"Exp", "[", "q", "]"}]}], "-", 
      RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"1", ",", 
      RowBox[{
       FractionBox["\[Delta]", "\[Gamma]"], 
       RowBox[{"Exp", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"-", "ConstE"}], "+", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"Exp", "[", "q", "]"}]}], "-", 
          RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "]"}]}]}], "]"}]}]}],
   ";"}]}], "Input",
 CellChangeTimes->{{3.979580835747961*^9, 3.979580886721244*^9}, {
  3.9795810872229023`*^9, 3.979581101665546*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"34a0e75e-0a53-4c5a-8e97-7b863a395d8b"]
}, Open  ]],

