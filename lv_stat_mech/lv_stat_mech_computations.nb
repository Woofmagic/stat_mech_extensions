 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"\[Alpha]", " ", "=", " ", 
     RowBox[{"2", "/", "3"}]}], ",", " ", 
    RowBox[{"\[Beta]", " ", "=", " ", 
     RowBox[{"4", "/", "3"}]}], ",", " ", 
