}, Open  ]],

Cell[TextData[{
 "Next, what is the numerical solution to what ",
 StyleBox["we think the integral is",
  FontSlant->"Italic"],
 ":"
}], "Text",
 CellChangeTimes->{{3.990804235112191*^9, 
  3.990804249440864*^9}},ExpressionUUID->"aba4675e-58c6-4fba-91e8-\
4cf69b92c01a"],

