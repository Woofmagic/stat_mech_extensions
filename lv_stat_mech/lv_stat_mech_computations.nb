Cell["\<\
(#3.2.1): Quantitative calculation using the standard formula:\
\>", "Subsection",
 CellChangeTimes->{{3.978713554945788*^9, 
  3.978713565260645*^9}},ExpressionUUID->"6fd4466f-4c94-4aa3-8e83-\
9eb26074dc68"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LVEnergyAverage", "=", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Log", "[", "LVZIntegral", "]"}], ",", "\[Theta]"}], "]"}]}], "//",
    "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.978713304060581*^9, 3.978713329379051*^9}, {
  3.978713972803824*^9, 3.978713974523026*^9}, {3.97940172147279*^9, 
