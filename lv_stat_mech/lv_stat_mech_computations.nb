         RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{"-", "ConstE"}], "\[Gamma]"], "]"}], 
