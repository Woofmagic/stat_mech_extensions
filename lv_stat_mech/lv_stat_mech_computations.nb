     SuperscriptBox["T", "3"]], ",", 
    RowBox[{"{", 
     RowBox[{"T", ",", "T1", ",", "T2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Assumptions", "->", 
     RowBox[{
      RowBox[{"T1", "\[Element]", "PositiveReals"}], "&&", 
      RowBox[{"T2", "\[Element]", "PositiveReals"}], "&&", 
      RowBox[{"\[Alpha]", "\[Element]", "PositiveReals"}], "&&", 
      RowBox[{"\[Gamma]", "\[Element]", "PositiveReals"}], "&&", 
      RowBox[{"T2", ">", "T1"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
