Cell["\<\
At zero temperature, the average energy is not zero. So, can we find the \
value of the thing at T = 0?
First, let\[CloseCurlyQuote]s get the analytical expression in terms of \
Temperature:\
\>", "Text",
 CellChangeTimes->{{3.981131266657052*^9, 3.981131324807508*^9}, {
  3.9884491802134666`*^9, 
  3.9884491975539303`*^9}},ExpressionUUID->"2fc6de28-24fe-4c78-acde-\
73bb7f91e4f1"],

Cell[BoxData[
 RowBox[{"LVEnergyAverage", "/.", 
  RowBox[{"\[Sigma]", "->", 
   FractionBox["1", "T"]}]}]], "Input",
 CellChangeTimes->{{3.981130696435981*^9, 3.981130699886409*^9}, 
   3.981131104106504*^9, {3.988449230211097*^9, 3.988449231452898*^9}, {
   3.988473535339015*^9, 3.988473535619636*^9}},
 CellLabel->
  "In[213]:=",ExpressionUUID->"eefc3578-419a-43ae-81bf-58091be8813d"],

Cell["\<\
Now, obviously evaluating this for T = 0 will lead to divergences. So, let\
\[CloseCurlyQuote]s determine its value numerically with a very small value \
for T.\
\>", "Text",
 CellChangeTimes->{{3.988449007351754*^9, 3.9884490098904057`*^9}, {
  3.988449199949551*^9, 3.9884492080645227`*^9}, {3.988449238288175*^9, 
  3.988449304018173*^9}},ExpressionUUID->"33ee6e56-56cd-4571-8e5e-\
8ddd28d7b3c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LVEnergyAverage", "/.", 
   RowBox[{"\[Sigma]", "->", 
    FractionBox["1", "T"]}]}], "/.", 
  RowBox[{"T", "->", "0.0000000000000000001"}]}]], "Input",
 CellChangeTimes->{{3.981130703367275*^9, 3.981130744155224*^9}, {
  3.981131333465356*^9, 3.981131346976598*^9}, {3.988449215561741*^9, 
  3.9884492931686907`*^9}, {3.9884735403451977`*^9, 3.9884735404568987`*^9}},
 CellLabel->
  "In[214]:=",ExpressionUUID->"78823e75-c9d1-4ebb-a52d-e63c76826816"],

Cell["\<\
That looks like it corresponds with what the plot is showing. Alright. Good \
check.\
\>", "Text",
 CellChangeTimes->{{3.988449308191791*^9, 
  3.9884493289142113`*^9}},ExpressionUUID->"ddeda58c-d285-4403-8fb6-\
2c42d6c46f3d"],

Cell["Next, let\[CloseCurlyQuote]s take a limit.", "Text",
 CellChangeTimes->{{3.9884493317661467`*^9, 
  3.9884493486718397`*^9}},ExpressionUUID->"1a977615-3eb3-4124-b239-\
963324897c66"],

Cell[BoxData[
 RowBox[{"Limit", "[", 
  RowBox[{
   RowBox[{"LVEnergyAverage", "/.", 
    RowBox[{"\[Sigma]", "->", 
     FractionBox["1", "T"]}]}], ",", 
   RowBox[{"T", "->", "0"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988473750204205*^9, 3.988473759220896*^9}},
 CellLabel->
  "In[215]:=",ExpressionUUID->"e0f9a1ff-9b3f-4836-a095-fd4151e1b0ff"],

Cell[TextData[{
 "Riiiight. That\[CloseCurlyQuote]s expected. [NOTE]: And it turns out that \
it actually has to do with the ",
 StyleBox["direction of the limit! ",
  FontSlant->"Italic"],
 "That is, we need to take the limit ",
 StyleBox["from the right!",
  FontSlant->"Italic"],
 "\nLet\[CloseCurlyQuote]s just try to copy/paste the analytical thing we got \
earlier:"
}], "Text",
 CellChangeTimes->{{3.988473767597763*^9, 3.9884737797766953`*^9}, {
  3.988473851800087*^9, 
  3.988473879456358*^9}},ExpressionUUID->"173082b5-0c9d-4370-885d-\
f8d957d39caf"],

Cell[BoxData[
 RowBox[{"Limit", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\[Alpha]", "+", "\[Gamma]", "+", 
    RowBox[{"\[Alpha]", " ", 
     RowBox[{"Log", "[", 
      FractionBox["\[Beta]", "T"], "]"}]}], "+", 
    RowBox[{"\[Gamma]", " ", 
     RowBox[{"Log", "[", 
      FractionBox["\[Delta]", "T"], "]"}]}], "-", 
    RowBox[{"\[Alpha]", " ", 
     RowBox[{"PolyGamma", "[", 
      RowBox[{"0", ",", 
       FractionBox["\[Alpha]", "T"]}], "]"}]}], "-", 
    RowBox[{"\[Gamma]", " ", 
     RowBox[{"PolyGamma", "[", 
      RowBox[{"0", ",", 
       FractionBox["\[Gamma]", "T"]}], "]"}]}]}], ",", "\[IndentingNewLine]", 
   
   RowBox[{"T", "->", "0"}], ",", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "strange", " ", "word", " ", "means", " ", 
     "\"\<take limit from the right\>\""}], " ", "*)"}], 
   "\[IndentingNewLine]", " ", 
   RowBox[{"Direction", "->", 
    RowBox[{"-", "1"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9884493398440123`*^9, 3.988449340843191*^9}, 
   3.988473572747407*^9, {3.988473657963565*^9, 3.988473684597764*^9}},
 CellLabel->
  "In[216]:=",ExpressionUUID->"a7e5b4f9-481c-4154-9110-f8267a3ea3f6"],

Cell["\<\
This should match with the earlier result, so their difference should be 0:\
