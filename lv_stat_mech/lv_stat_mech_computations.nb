Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Integrate", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"0", ",", "x"}], "]"}]}], "+", 
      RowBox[{"ProductLog", "[", 
       RowBox[{"1", ",", "x"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "a", ",", " ", "b"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"a", ">", "0"}], "&&", 
     RowBox[{"b", ">", "0"}], "&&", 
     RowBox[{"b", ">", "a"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.978789331264576*^9, 3.97878943612733*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"cd4419c4-9c3c-42ff-a3e6-9695aaf48351"],

