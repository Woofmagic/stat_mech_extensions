        FractionBox["1", "T"]}]}], ",", "T"}], "]"}], ")"}], "-", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "T"], 
     FractionBox[
      RowBox[{
       RowBox[{"-", "\[Alpha]"}], "-", "\[Gamma]", "+", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[Alpha]", "2"], " ", 
         RowBox[{"PolyGamma", "[", 
          RowBox[{"1", ",", 
           FractionBox["\[Alpha]", "T"]}], "]"}]}], "T"], "+", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[Gamma]", "2"], " ", 
         RowBox[{"PolyGamma", "[", 
          RowBox[{"1", ",", 
           FractionBox["\[Gamma]", "T"]}], "]"}]}], "T"]}], "T"]}], ")"}]}], "//",
   "FullSimplify"}]], "Input",
