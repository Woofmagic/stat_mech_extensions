  3.97862737017765*^9}},ExpressionUUID->"12ebe4d4-2b62-4e25-90d5-\
e84f6e4f10f8"],

Cell[CellGroupData[{

Cell["(#1.1): \[OpenCurlyDoubleQuote]Standard LV Hamiltonian\
\[CloseCurlyDoubleQuote]", "Section",
 CellChangeTimes->{{3.978627371872817*^9, 
  3.978627380685585*^9}},ExpressionUUID->"f76aac37-f67c-4b23-a98f-\
0a812cab6765"],

Cell[CellGroupData[{

Cell["(#1.1.1): Defining the Hamiltonian:", "Subsection",
 CellChangeTimes->{{3.97862744919598*^9, 
  3.978627453528882*^9}},ExpressionUUID->"aaad9fd2-23d5-4e9f-8ae7-\
d1dcb8dcdd3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LVHamiltonian", "[", 
    RowBox[{"q_", ",", "p_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"\[Delta]", " ", 
     RowBox[{"Exp", "[", "p", "]"}]}], "-", 
    RowBox[{"\[Gamma]", " ", "p"}], " ", "+", " ", 
    RowBox[{"\[Beta]", " ", 
     RowBox[{"Exp", "[", "q", "]"}]}], "-", 
    RowBox[{"\[Alpha]", " ", "q"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9786273818456984`*^9, 3.97862741195427*^9}},
 CellLabel->
  "In[133]:=",ExpressionUUID->"290e2934-a1ff-48d0-bb0a-4f8faa772360"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#1.1.2): Can we easily exponentiate it without Mathematica freaking out?\
\>", "Subsection",
 CellChangeTimes->{{3.978627422029333*^9, 3.9786274352895613`*^9}, {
  3.981128296964848*^9, 
  3.98112830509867*^9}},ExpressionUUID->"5709f56f-20cf-46e0-bb72-\
5e6a594e9a05"],

Cell[BoxData[
 RowBox[{"Exp", "[", 
  RowBox[{"LVHamiltonian", "[", 
   RowBox[{"q", ",", "p"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9786274364905977`*^9, 3.9786274400246687`*^9}},
 CellLabel->
  "In[134]:=",ExpressionUUID->"6d33dbf5-c3c3-4447-816e-f123d62d6cc0"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

