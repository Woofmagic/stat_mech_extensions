Cell[CellGroupData[{

Cell["(#2.1.2): Trying to Solve for the Bounding Functions:", "Subsection",
 CellChangeTimes->{
  3.978720655064846*^9, {3.9787891519691677`*^9, 3.978789154337585*^9}, {
   3.978789326927298*^9, 3.978789329039371*^9}, {3.979580657697672*^9, 
   3.97958066849468*^9}},ExpressionUUID->"fb56afea-86ef-49d6-94db-\
bedac5e138b7"],

Cell[CellGroupData[{

Cell["\<\
(#2.1.2.1): Seeing how many Solutions are found for the Implicit Equation:\
\>", "Subsubsection",
 CellChangeTimes->{{3.979580799195891*^9, 
  3.979580813718585*^9}},ExpressionUUID->"d5a3613b-0054-40f5-9ad2-\
57cf1cf7bb82"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"ConstE", "==", 
      RowBox[{"LVHamiltonian", "[", 
       RowBox[{"q", ",", "p"}], "]"}]}], ",", "p"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Assumptions", "->", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[Infinity]"}], "<", "q", "<", "\[Infinity]"}], "&&", 
     RowBox[{
      RowBox[{"-", "\[Infinity]"}], "<", "p", "<", "\[Infinity]"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"ConstE", "\[Element]", "Reals"}], "&&", 
     RowBox[{"\[Alpha]", "\[Element]", "Reals"}], "&&", 
     RowBox[{"\[Beta]", "\[Element]", "Reals"}], "&&", 
     RowBox[{"\[Delta]", "\[Element]", "Reals"}], "&&", 
     RowBox[{"\[Gamma]", "\[Element]", "Reals"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9787164165407143`*^9, 3.978716517425126*^9}, {
  3.978716598636434*^9, 3.978716626713106*^9}, {3.9787857473731422`*^9, 
  3.978785747526458*^9}, {3.9787866533566017`*^9, 3.978786664561541*^9}, {
  3.979580739096911*^9, 3.9795807778709793`*^9}, {3.987938444883279*^9, 
  3.987938449860599*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"1727c2a8-04b5-4d29-b1a8-399be4c6b359"],

Cell[BoxData[
 TemplateBox[{
  "Solve", "ifun", 
   "\"Inverse functions are being used by \
\\!\\(\\*RowBox[{\\\"Solve\\\"}]\\), so some solutions may not be found; use \
Reduce for complete solution information.\"", 2, 6, 1, 31474836364403668408, 
   "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellChangeTimes->{{3.979580748369028*^9, 3.979580779156376*^9}, 
   3.9795808152582397`*^9, 3.979665878630701*^9, 3.981128567455147*^9, {
