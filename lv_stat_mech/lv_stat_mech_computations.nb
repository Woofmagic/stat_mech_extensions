Cell["(#3.X.Y): Fischer Information Metric:", "Subsubsection",
 CellChangeTimes->{{3.9794002274814253`*^9, 
  3.9794002390989523`*^9}},ExpressionUUID->"313da51c-2175-4828-86af-\
a7140fc09466"],

Cell["\<\
The metric is one-dimensional because there is only one Lagrange multiplier \
in the Partition Function above.\
\>", "Text",
 CellChangeTimes->{{3.979400240664818*^9, 
  3.979400266358737*^9}},ExpressionUUID->"11e5bd2a-38d9-4fff-bc91-\
43687c4c32f9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FischerMetric11LV", "=", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Log", "[", "LVZIntegral", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "2"}], "}"}]}], "]"}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.979400280420279*^9, 3.979400321139805*^9}, {
  3.979667048507616*^9, 3.979667054452237*^9}, {3.979667092799477*^9, 
  3.9796670945713587`*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"9a11652c-cbd1-4b21-9338-650a5e270156"],

Cell[BoxData[
 TemplateBox[{
   FractionBox[
    RowBox[{"\[Alpha]", "+", "\[Gamma]", "-", 
      RowBox[{"\[Theta]", " ", 
        RowBox[{"(", 
          RowBox[{
            RowBox[{
              SuperscriptBox["\[Alpha]", "2"], " ", 
              RowBox[{"PolyGamma", "[", 
                RowBox[{"1", ",", 
                  RowBox[{"\[Alpha]", " ", "\[Theta]"}]}], "]"}]}], "+", 
            RowBox[{
              SuperscriptBox["\[Gamma]", "2"], " ", 
              RowBox[{"PolyGamma", "[", 
                RowBox[{"1", ",", 
                  RowBox[{"\[Gamma]", " ", "\[Theta]"}]}], "]"}]}]}], 
          ")"}]}]}], "\[Theta]"], 
   RowBox[{
     RowBox[{"(", 
       RowBox[{
         RowBox[{"\[Alpha]", ">", "0"}], "&&", 
         RowBox[{"\[Beta]", ">", "0"}], "&&", 
         RowBox[{"\[Theta]", ">", "0"}]}], ")"}], "||", 
     RowBox[{"(", 
       RowBox[{
         RowBox[{"\[Alpha]", "<", "0"}], "&&", 
         RowBox[{"\[Beta]", "<", "0"}], "&&", 
         RowBox[{"\[Theta]", "<", "0"}]}], ")"}]}]},
  "ConditionalExpression"]], "Output",
 CellChangeTimes->{{3.979400300511312*^9, 3.97940032344982*^9}, 
