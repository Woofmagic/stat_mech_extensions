   RowBox[{"LVHamiltonian", "[", 
    RowBox[{"q", ",", "p"}], "]"}], "/.", 
   RowBox[{"p", "->", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"ConstE", "+", 
       RowBox[{"q", " ", "\[Alpha]"}], "-", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}], "+", 
       RowBox[{"\[Gamma]", " ", 
        RowBox[{"ProductLog", "[", 
         RowBox[{"0", ",", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"-", 
               FractionBox[
                RowBox[{"ConstE", "+", 
                 RowBox[{"q", " ", "\[Alpha]"}], "-", 
                 RowBox[{
                  SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}], 
                "\[Gamma]"]}]], " ", "\[Delta]"}], "\[Gamma]"]}]}], "]"}]}]}],
       "\[Gamma]"]}]}]}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.987938521634659*^9, 3.9879385663542137`*^9}},
