Notebook[{

Cell[CellGroupData[{
Cell["\<\
Calculation of Statistical-Mechanical Quantities of Lotka-Volterra Hamiltonian\
\>", "Title",
 CellChangeTimes->{{3.978627177014625*^9, 
  3.978627205752421*^9}},ExpressionUUID->"5a3bd287-bd54-4ca2-a3a9-\
4744b03949c7"],

Cell[CellGroupData[{

Cell["(#0): Pre-notebook Stuff:", "Chapter",
 CellChangeTimes->{{3.992104176728443*^9, 
  3.992104181212434*^9}},ExpressionUUID->"ed6f45f6-94b4-4fb3-9b90-\
ae0405ca553f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T", "\[Element]", "PositiveReals"}], "&&", " ", 
     RowBox[{"(*", " ", "temperature", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"\[Sigma]", "\[Element]", "PositiveReals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"inverse", " ", "temperature"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"ConstE", "\[Element]", "Reals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"the", " ", "\"\<energy\>\""}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"q", "\[Element]", "Reals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"new", " ", "coordinate"}], ",", " ", 
       RowBox[{"generalized", " ", "position"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"p", "\[Element]", "Reals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"new", " ", "coordinate"}], ",", " ", 
       RowBox[{"conjugate", " ", "momentum"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]", "\[Element]", "PositiveReals"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Beta]", "\[Element]", "PositiveReals"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Gamma]", "\[Element]", "PositiveReals"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Delta]", "\[Element]", "PositiveReals"}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9921041846409197`*^9, 3.9921042829246483`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"46fd515b-7c4d-44e7-a5eb-3223feb80d70"]
}, Open  ]],

Cell[CellGroupData[{

Cell["(#1): Requisite Data:", "Chapter",
 CellChangeTimes->{{3.978627359758678*^9, 
  3.97862737017765*^9}},ExpressionUUID->"12ebe4d4-2b62-4e25-90d5-\
e84f6e4f10f8"],

Cell[CellGroupData[{

Cell["(#1.1): \[OpenCurlyDoubleQuote]Standard LV Hamiltonian\
\[CloseCurlyDoubleQuote]", "Section",
 CellChangeTimes->{{3.978627371872817*^9, 
  3.978627380685585*^9}},ExpressionUUID->"f76aac37-f67c-4b23-a98f-\
0a812cab6765"],

Cell[CellGroupData[{

Cell["(#1.1.1): Defining the Hamiltonian:", "Subsection",
 CellChangeTimes->{{3.97862744919598*^9, 
  3.978627453528882*^9}},ExpressionUUID->"aaad9fd2-23d5-4e9f-8ae7-\
d1dcb8dcdd3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LVHamiltonian", "[", 
    RowBox[{"q_", ",", "p_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"\[Delta]", " ", 
     RowBox[{"Exp", "[", "p", "]"}]}], "-", 
    RowBox[{"\[Gamma]", " ", "p"}], " ", "+", " ", 
    RowBox[{"\[Beta]", " ", 
     RowBox[{"Exp", "[", "q", "]"}]}], "-", 
    RowBox[{"\[Alpha]", " ", "q"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9786273818456984`*^9, 3.97862741195427*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"290e2934-a1ff-48d0-bb0a-4f8faa772360"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#1.1.2): Can we easily exponentiate it without Mathematica freaking out?\
\>", "Subsection",
 CellChangeTimes->{{3.978627422029333*^9, 3.9786274352895613`*^9}, {
  3.981128296964848*^9, 
  3.98112830509867*^9}},ExpressionUUID->"5709f56f-20cf-46e0-bb72-\
5e6a594e9a05"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Exp", "[", 
  RowBox[{"LVHamiltonian", "[", 
   RowBox[{"q", ",", "p"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9786274364905977`*^9, 3.9786274400246687`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"6d33dbf5-c3c3-4447-816e-f123d62d6cc0"],

Cell[BoxData[
 SuperscriptBox["\[ExponentialE]", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "q"}], " ", "\[Alpha]"}], "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}], "-", 
   RowBox[{"p", " ", "\[Gamma]"}], "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", "p"], " ", "\[Delta]"}]}]]], "Output",
 CellChangeTimes->{3.992177468901123*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"6ee97ab8-c827-4881-8027-da2b1b34eef9"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(#2): Microcanonical Ensemble Analysis (\[OpenCurlyDoubleQuote]Standard \
Hamiltonian\[CloseCurlyDoubleQuote]):\
\>", "Chapter",
 CellChangeTimes->{{3.978627216637786*^9, 3.978627233812749*^9}, {
  3.9786273473367167`*^9, 
  3.978627355863928*^9}},ExpressionUUID->"1046b142-27d8-4c1e-8d1d-\
0b6ce8eb0a29"],

Cell[CellGroupData[{

Cell["(#2.1): Obtaining the Area Enclosed by Phase Space Orbits:", "Section",
 CellChangeTimes->{{3.978716409020054*^9, 3.978716415585292*^9}, {
  3.9787887180763474`*^9, 
  3.978788728917823*^9}},ExpressionUUID->"7cb83939-9411-4262-8c78-\
4032b05684f0"],

Cell[CellGroupData[{

Cell["(#2.1.1): Making a plot for visualizing the orbits:", "Subsection",
 CellChangeTimes->{{3.9787887305980263`*^9, 
  3.978788749156514*^9}},ExpressionUUID->"153c8b87-f659-4626-b114-\
5a1e46c16ba8"],

Cell["\<\
Using the following article for the values of the parameter: \
https://en.wikipedia.org/wiki/Lotka%E2%80%93Volterra_equations#Phase-space_\
plot_of_a_further_example\
\>", "Text",
 CellChangeTimes->{{3.978789075910502*^9, 
  3.978789082223371*^9}},ExpressionUUID->"7e430c3a-e0fc-4146-b793-\
f18f2acb0ab1"],

Cell[CellGroupData[{

Cell["(#2.1.1.1): The LV Hamiltonian:", "Subsubsection",
 CellChangeTimes->{{3.9795802071335773`*^9, 
  3.979580213656735*^9}},ExpressionUUID->"88104069-1c1a-4c6f-ba13-\
62692fe1f01b"],

Cell["\<\
For initial conditions of p = 0.9 and q = 0.9, the constant of the motion \
under the designation of the four model parameters below is:\
\>", "Text",
 CellChangeTimes->{{3.979580582482852*^9, 
  3.979580607437624*^9}},ExpressionUUID->"5069d0de-ba45-441d-9a04-\
c18059eb4d7a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"LVHamiltonian", "[", 
      RowBox[{"0.9", ",", "0.9"}], "]"}], "/.", 
     RowBox[{"\[Alpha]", "->", 
      FractionBox["2", "3"]}]}], "/.", 
    RowBox[{"\[Beta]", "->", 
     FractionBox["4", "3"]}]}], "/.", 
   RowBox[{"\[Gamma]", "->", "1"}]}], "/.", 
  RowBox[{"\[Delta]", "->", "1"}]}]], "Input",
 CellChangeTimes->{{3.978788883261161*^9, 3.978788885528715*^9}, {
   3.978789087532275*^9, 3.978789106563046*^9}, 3.979580367100677*^9, {
   3.979580411411729*^9, 3.97958042305995*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"57010c7d-d7a7-4021-8710-7e2d665b7d00"],

Cell[BoxData["4.239073926032883`"], "Output",
 CellChangeTimes->{3.9921774689320097`*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"9c3305de-06b8-4c6d-9fe0-f830350465d1"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "(#2.1.1.2): The Plot: ([NOTE]: New phase space variables can be negative ",
 StyleBox["and",
  FontSlant->"Italic"],
 " positive!)"
}], "Subsubsection",
 CellChangeTimes->{{3.9795802187487783`*^9, 3.979580224436159*^9}, {
  3.981128331202279*^9, 3.981128348641069*^9}, {3.9811284928613567`*^9, 
  3.981128493660948*^9}},ExpressionUUID->"02d71475-11b4-4999-9267-\
1384befb398e"],

Cell["\<\
The space is foliated, but it looks like a strange shape (i.e. not \
ellipsoidal, obviously). Topologically equivalent to torus, probably.\
\>", "Text",
 CellChangeTimes->{{3.981128532890792*^9, 
  3.981128561840475*^9}},ExpressionUUID->"6d207254-e580-4fa3-9fa8-\
90082415c2f1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", "p"], "+", 
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["\[ExponentialE]", "q"]}], "3"], "-", "p", "-", 
    FractionBox[
     RowBox[{"2", " ", "q"}], "3"]}], ",", 
   RowBox[{"{", 
    RowBox[{"q", ",", 
     RowBox[{"-", "5"}], ",", "10"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"p", ",", 
     RowBox[{"-", "5"}], ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.979580259501973*^9, 3.979580346705676*^9}, {
  3.979580426384983*^9, 3.979580429311884*^9}, {3.9795805373745537`*^9, 
