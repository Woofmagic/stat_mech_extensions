   RowBox[{"ProductLog", "[", "b", "]"}]], "-", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"ProductLog", "[", 
    RowBox[{"1", ",", "a"}], "]"}]], "+", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"ProductLog", "[", 
    RowBox[{"1", ",", "b"}], "]"}]], "+", 
  RowBox[{"a", " ", 
   RowBox[{"ProductLog", "[", "a", "]"}]}], "-", 
  RowBox[{"b", " ", 
   RowBox[{"ProductLog", "[", "b", "]"}]}], "-", 
  RowBox[{"a", " ", 
   RowBox[{"ProductLog", "[", 
    RowBox[{"1", ",", "a"}], "]"}]}], "+", 
  RowBox[{"b", " ", 
   RowBox[{"ProductLog", "[", 
    RowBox[{"1", ",", "b"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.992177471705656*^9},
 CellLabel->"Out[13]=",ExpressionUUID->"c8b6887a-d04a-42f4-994e-6c7d94e44f34"]
}, Open  ]]
