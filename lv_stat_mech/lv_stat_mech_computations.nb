Cell[BoxData[
 RowBox[{"ChangeInLVEntropy", "=", 
  RowBox[{"Integrate", "[", "\[IndentingNewLine]", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"-", "T"}], " ", 
       RowBox[{"(", 
        RowBox[{"\[Alpha]", "+", "\[Gamma]"}], ")"}]}], "+", 
      RowBox[{
       SuperscriptBox["\[Alpha]", "2"], " ", 
       RowBox[{"PolyGamma", "[", 
        RowBox[{"1", ",", 
