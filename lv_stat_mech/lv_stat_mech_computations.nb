Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{"-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"1", ",", 
      RowBox[{"-", 
       FractionBox["\[Delta]", "\[Gamma]"]}]}], "]"}]}], "-", 
   FractionBox["ConstE", 
    RowBox[{"\[Gamma]", "+", 
     RowBox[{"\[Gamma]", " ", 
      RowBox[{"ProductLog", "[", 
       RowBox[{"1", ",", 
        RowBox[{"-", 
         FractionBox["\[Delta]", "\[Gamma]"]}]}], "]"}]}]}]], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "ConstE", "]"}], "2"],
    SeriesData[$CellContext`ConstE, 0, {}, 0, 2, 1],
    Editable->False]}],
  SeriesData[$CellContext`ConstE, 
   0, {-ProductLog[
     1, -$CellContext`\[Gamma]^(-1) $CellContext`\[Delta]], \
(-1)/($CellContext`\[Gamma] + $CellContext`\[Gamma] 
     ProductLog[1, -$CellContext`\[Gamma]^(-1) $CellContext`\[Delta]])}, 0, 2,
    1],
  Editable->False]], "Output",
 CellChangeTimes->{3.992177480056015*^9},
 CellLabel->"Out[50]=",ExpressionUUID->"39517f9d-a828-45ea-bd1f-0c6bf241ec1f"]
}, Open  ]]
}, Closed]],

