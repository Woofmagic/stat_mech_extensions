 RowBox[{
  RowBox[{
   SqrtBox[
    RowBox[{"(", 
     RowBox[{"ConstE", "+", 
      RowBox[{"q", " ", "\[Alpha]"}], "-", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}], ")"}]], 
   "-", 
   SqrtBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "\[Beta]"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Exp", "[", "q", "]"}], "-", 
        RowBox[{
         FractionBox["\[Alpha]", "\[Beta]"], "q"}], "-", 
        FractionBox["ConstE", "\[Beta]"]}], ")"}]}], ")"}]]}], "//", 
  "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.990277365437557*^9, 3.990277486870352*^9}, {
  3.990277775296215*^9, 3.990277776967675*^9}},
 CellLabel->
  "In[196]:=",ExpressionUUID->"bf2602a8-80e3-4d6b-8d17-7e77b236a6ce"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"2", " "}], 
       SqrtBox["\[Delta]"]], 
      SqrtBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "\[Beta]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Exp", "[", "q", "]"}], "-", 
           RowBox[{
            FractionBox["\[Alpha]", "\[Beta]"], "q"}], "-", 
           FractionBox["ConstE", "\[Beta]"]}], ")"}]}], ")"}]]}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", " ", "a", ",", " ", "b"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"e", ".."}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9902777994718027`*^9, 3.990277851798077*^9}},
 CellLabel->
  "In[197]:=",ExpressionUUID->"c13dc27a-bf71-4ea3-a700-ce4602b55a8f"],

