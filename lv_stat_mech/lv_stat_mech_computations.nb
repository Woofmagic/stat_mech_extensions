  3.988453609229251*^9}},ExpressionUUID->"64d6f604-ddd8-465c-baf6-\
c00189787573"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MaxBoltMomentumDistribution", "=", 
   RowBox[{
