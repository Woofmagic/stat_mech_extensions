Cell[CellGroupData[{

Cell["(#2.1.3.2): Manually entering the solutions:", "Subsubsection",
 CellChangeTimes->{{3.990743521175724*^9, 
  3.99074352928769*^9}},ExpressionUUID->"a277dfd7-6122-4205-9456-\
21c92c7baf8a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pPlusDimensionless", "=", 
   RowBox[{"-", 
    FractionBox["1", "\[Gamma]"], 
    RowBox[{"(", 
     RowBox[{"ConstE", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["\[ExponentialE]", "q"]}], "+", "q"}], ")"}], " ", 
       "\[Alpha]"}], "+", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"0", ",", 
         RowBox[{"-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"-", 
            FractionBox[
             RowBox[{"ConstE", "-", 
              RowBox[{
               SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "+", 
              RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}]]}]}], "]"}]}]}],
      ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pMinusDimensionless", "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "\[Gamma]"]}], 
    RowBox[{"(", 
     RowBox[{"ConstE", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["\[ExponentialE]", "q"]}], "+", "q"}], ")"}], " ", 
       "\[Alpha]"}], "+", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"1", ",", 
         RowBox[{"-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"-", 
            FractionBox[
             RowBox[{"ConstE", "-", 
              RowBox[{
               SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "+", 
              RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}]]}]}], "]"}]}]}],
      ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.990743501243352*^9, 3.990743552898891*^9}, {
  3.991777334652363*^9, 3.991777340128068*^9}},
 CellLabel->
  "In[157]:=",ExpressionUUID->"067280d0-8069-438a-a7cc-0d747ff5bc4e"],

Cell["Checking it:", "Text",
 CellChangeTimes->{{3.991777294667623*^9, 
  3.991777296572053*^9}},ExpressionUUID->"2003a0c1-b2b1-4449-a21c-\
5272f00ab288"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Gamma]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Exp", "[", "p", "]"}], "-", "p"}], ")"}]}], " ", "+", " ", 
    RowBox[{"\[Alpha]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Exp", "[", "q", "]"}], "-", "q"}], ")"}]}]}], "/.", 
   RowBox[{"p", "->", "pPlusDimensionless"}]}], "//", 
  "FullSimplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Gamma]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Exp", "[", "p", "]"}], "-", "p"}], ")"}]}], " ", "+", " ", 
    RowBox[{"\[Alpha]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Exp", "[", "q", "]"}], "-", "q"}], ")"}]}]}], "/.", 
   RowBox[{"p", "->", "pMinusDimensionless"}]}], "//", 
  "FullSimplify"}]}], "Input",
 CellChangeTimes->{{3.991777297452469*^9, 3.991777315139841*^9}},
 CellLabel->
  "In[159]:=",ExpressionUUID->"372924d8-37d0-4a37-90da-91c43489c5c2"]
}, Closed]],

