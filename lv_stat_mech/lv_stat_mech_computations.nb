Cell[BoxData[
 TemplateBox[{
   RowBox[{"\[Alpha]", "+", "\[Gamma]", "+", 
     RowBox[{"\[Alpha]", " ", 
       RowBox[{"Log", "[", 
         RowBox[{"\[Beta]", " ", "\[Theta]"}], "]"}]}], "+", 
     RowBox[{"\[Gamma]", " ", 
       RowBox[{"Log", "[", 
         RowBox[{"\[Delta]", " ", "\[Theta]"}], "]"}]}], "-", 
     RowBox[{"\[Alpha]", " ", 
       RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
           RowBox[{"\[Alpha]", " ", "\[Theta]"}]}], "]"}]}], "-", 
     RowBox[{"\[Gamma]", " ", 
       RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
           RowBox[{"\[Gamma]", " ", "\[Theta]"}]}], "]"}]}]}], 
   RowBox[{
     RowBox[{"(", 
       RowBox[{
         RowBox[{"\[Alpha]", ">", "0"}], "&&", 
         RowBox[{"\[Beta]", ">", "0"}], "&&", 
         RowBox[{"\[Theta]", ">", "0"}]}], ")"}], "||", 
     RowBox[{"(", 
       RowBox[{
         RowBox[{"\[Alpha]", "<", "0"}], "&&", 
         RowBox[{"\[Beta]", "<", "0"}], "&&", 
         RowBox[{"\[Theta]", "<", "0"}]}], ")"}]}]},
  "ConditionalExpression"]], "Output",
 CellChangeTimes->{{3.9787133258292*^9, 3.978713329791321*^9}, 
