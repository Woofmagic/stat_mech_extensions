Cell[CellGroupData[{

Cell["(#3.5.2): Entropy of Mixing:", "Subsection",
 CellChangeTimes->{{3.990280027796591*^9, 3.990280033197494*^9}, {
  3.990287668698778*^9, 
  3.99028766972655*^9}},ExpressionUUID->"581bd23f-43f8-4551-bfbb-\
e2da453109d2"],

Cell["\<\
Entropy is an equilibrium (additive!) state function. So, let\
\[CloseCurlyQuote]s compare the entropy before and after mixing of two \
systems at the same temperature:\
\>", "Text",
 CellChangeTimes->{{3.990280035544071*^9, 
  3.990280075345366*^9}},ExpressionUUID->"487dafdb-1aeb-4c3f-bbf3-\
064853535425"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"CombinedSystemsLVEntropy", "=", 
   RowBox[{
    RowBox[{"\[Sigma]", " ", 
     RowBox[{"(", 
      RowBox[{"\[Alpha]C", "+", "\[Gamma]C", "+", 
       RowBox[{"\[Gamma]C", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"\[Delta]C", " ", "\[Sigma]"}], "]"}]}]}], ")"}]}], "+", 
    RowBox[{"Log", "[", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Delta]C", " ", "\[Sigma]"}], ")"}], 
       RowBox[{
        RowBox[{"-", "\[Gamma]C"}], " ", "\[Sigma]"}]], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[Alpha]C", " ", "\[Sigma]"}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[Gamma]C", " ", "\[Sigma]"}], "]"}]}], "]"}], "-", 
    RowBox[{"\[Sigma]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Alpha]C", " ", 
        RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
          RowBox[{"\[Alpha]C", " ", "\[Sigma]"}]}], "]"}]}], "+", 
       RowBox[{"\[Gamma]C", " ", 
        RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
          RowBox[{"\[Gamma]C", " ", "\[Sigma]"}]}], "]"}]}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TwoSeparatedSystemsLVEntropy", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", 
       RowBox[{"(", 
        RowBox[{"\[Alpha]1", "+", "\[Gamma]1", "+", 
         RowBox[{"\[Gamma]1", " ", 
          RowBox[{"Log", "[", 
           RowBox[{"\[Delta]1", " ", "\[Sigma]"}], "]"}]}]}], ")"}]}], "+", 
      RowBox[{"Log", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"\[Delta]1", " ", "\[Sigma]"}], ")"}], 
         RowBox[{
          RowBox[{"-", "\[Gamma]1"}], " ", "\[Sigma]"}]], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[Alpha]1", " ", "\[Sigma]"}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[Gamma]1", " ", "\[Sigma]"}], "]"}]}], "]"}], "-", 
      RowBox[{"\[Sigma]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Alpha]1", " ", 
          RowBox[{"PolyGamma", "[", 
           RowBox[{"0", ",", 
            RowBox[{"\[Alpha]1", " ", "\[Sigma]"}]}], "]"}]}], "+", 
         RowBox[{"\[Gamma]1", " ", 
          RowBox[{"PolyGamma", "[", 
           RowBox[{"0", ",", 
            RowBox[{"\[Gamma]1", " ", "\[Sigma]"}]}], "]"}]}]}], ")"}]}]}], 
     ")"}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", 
       RowBox[{"(", 
        RowBox[{"\[Alpha]2", "+", "\[Gamma]2", "+", 
         RowBox[{"\[Gamma]2", " ", 
          RowBox[{"Log", "[", 
           RowBox[{"\[Delta]2", " ", "\[Sigma]"}], "]"}]}]}], ")"}]}], "+", 
      RowBox[{"Log", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"\[Delta]2", " ", "\[Sigma]"}], ")"}], 
         RowBox[{
          RowBox[{"-", "\[Gamma]2"}], " ", "\[Sigma]"}]], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[Alpha]2", " ", "\[Sigma]"}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[Gamma]2", " ", "\[Sigma]"}], "]"}]}], "]"}], "-", 
      RowBox[{"\[Sigma]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Alpha]2", " ", 
          RowBox[{"PolyGamma", "[", 
           RowBox[{"0", ",", 
            RowBox[{"\[Alpha]2", " ", "\[Sigma]"}]}], "]"}]}], "+", 
         RowBox[{"\[Gamma]2", " ", 
          RowBox[{"PolyGamma", "[", 
           RowBox[{"0", ",", 
            RowBox[{"\[Gamma]2", " ", "\[Sigma]"}]}], "]"}]}]}], ")"}]}]}], 
     ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.990280065302236*^9, 3.990280226151849*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"7be3337a-149f-4cf0-91bc-f3a8f8575a89"],

