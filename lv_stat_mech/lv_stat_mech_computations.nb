bedac5e138b7"],

Cell[CellGroupData[{

Cell["\<\
(#2.1.2.1): Seeing how many Solutions are found for the Implicit Equation:\
\>", "Subsubsection",
 CellChangeTimes->{{3.979580799195891*^9, 
  3.979580813718585*^9}},ExpressionUUID->"d5a3613b-0054-40f5-9ad2-\
57cf1cf7bb82"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"ConstE", "==", 
     RowBox[{"LVHamiltonian", "[", 
      RowBox[{"q", ",", "p"}], "]"}]}], ",", "p"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9787164165407143`*^9, 3.978716517425126*^9}, {
  3.978716598636434*^9, 3.978716626713106*^9}, {3.9787857473731422`*^9, 
  3.978785747526458*^9}, {3.9787866533566017`*^9, 3.978786664561541*^9}, {
  3.979580739096911*^9, 3.9795807778709793`*^9}, {3.987938444883279*^9, 
  3.987938449860599*^9}, {3.990743456035582*^9, 3.990743459457157*^9}, {
  3.9921042906365337`*^9, 3.992104291491764*^9}},
 CellLabel->
  "In[138]:=",ExpressionUUID->"1727c2a8-04b5-4d29-b1a8-399be4c6b359"],

Cell["\<\
Only one solution is found... That is likely because, although we specified \
that \[Alpha], \[Beta], \[Gamma], and \[Delta] are positive, we did not \
specify their relative differences.\
\>", "Text",
 CellChangeTimes->{{3.979580672400153*^9, 
  3.979580732114024*^9}},ExpressionUUID->"b9313a2f-6bf6-4329-8136-\
0c1726fd515d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LVHamiltonian", "[", 
    RowBox[{"q", ",", "p"}], "]"}], "/.", 
   RowBox[{"p", "->", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"ConstE", "+", 
       RowBox[{"q", " ", "\[Alpha]"}], "-", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}], "+", 
       RowBox[{"\[Gamma]", " ", 
        RowBox[{"ProductLog", "[", 
         RowBox[{"0", ",", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"-", 
               FractionBox[
                RowBox[{"ConstE", "+", 
                 RowBox[{"q", " ", "\[Alpha]"}], "-", 
                 RowBox[{
                  SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}], 
                "\[Gamma]"]}]], " ", "\[Delta]"}], "\[Gamma]"]}]}], "]"}]}]}],
       "\[Gamma]"]}]}]}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.987938521634659*^9, 3.9879385663542137`*^9}},
 CellLabel->
  "In[139]:=",ExpressionUUID->"9cdaf90f-1206-4517-8d7c-8ae9b1e953a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LVHamiltonian", "[", 
    RowBox[{"q", ",", "p"}], "]"}], "/.", 
   RowBox[{"p", "->", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"ConstE", "+", 
       RowBox[{"q", " ", "\[Alpha]"}], "-", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}], "+", 
       RowBox[{"\[Gamma]", " ", 
        RowBox[{"ProductLog", "[", 
         RowBox[{"1", ",", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"-", 
               FractionBox[
                RowBox[{"ConstE", "+", 
                 RowBox[{"q", " ", "\[Alpha]"}], "-", 
                 RowBox[{
                  SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}], 
                "\[Gamma]"]}]], " ", "\[Delta]"}], "\[Gamma]"]}]}], "]"}]}]}],
       "\[Gamma]"]}]}]}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.9879385777026997`*^9, 3.987938577778433*^9}},
 CellLabel->
  "In[140]:=",ExpressionUUID->"c0991c1f-cea0-4c4b-a092-24f52aad62bc"],

Cell["Wow! It actually works. Nice!", "Text",
 CellChangeTimes->{{3.987938598167737*^9, 
  3.987938603347875*^9}},ExpressionUUID->"c27692fa-f360-4c82-a1ce-\
df16fbabbedb"]
}, Closed]],

Cell[CellGroupData[{

Cell["(#2.1.2.2): Manually Entering the Solutions We Got:", "Subsubsection",
 CellChangeTimes->{{3.979580820672736*^9, 
  3.9795808349077806`*^9}},ExpressionUUID->"f3efd2f8-af2d-4380-be99-\
0abaad054ffa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pPlus", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "ConstE"}], "+", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"Exp", "[", "q", "]"}]}], "-", 
      RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"0", ",", 
      RowBox[{
       FractionBox["\[Delta]", "\[Gamma]"], 
       RowBox[{"Exp", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"-", "ConstE"}], "+", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"Exp", "[", "q", "]"}]}], "-", 
          RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "]"}]}]}], "]"}]}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pMinus", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "ConstE"}], "+", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"Exp", "[", "q", "]"}]}], "-", 
      RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"1", ",", 
      RowBox[{
       FractionBox["\[Delta]", "\[Gamma]"], 
       RowBox[{"Exp", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"-", "ConstE"}], "+", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"Exp", "[", "q", "]"}]}], "-", 
          RowBox[{"\[Alpha]", " ", "q"}]}], "\[Gamma]"], "]"}]}]}], "]"}]}]}],
   ";"}]}], "Input",
 CellChangeTimes->{{3.979580835747961*^9, 3.979580886721244*^9}, {
  3.9795810872229023`*^9, 3.979581101665546*^9}},
 CellLabel->
  "In[141]:=",ExpressionUUID->"34a0e75e-0a53-4c5a-8e97-7b863a395d8b"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "(#2.1.2.3): Since the first integral is just over 1, the integrand for the \
next integral is just ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["p", "+"], "-", 
    SuperscriptBox["p", "-"]}], TraditionalForm]],ExpressionUUID->
  "53277009-2f9b-40ef-b968-937e4bc5112d"],
 ". So, what is that?"
}], "Subsubsection",
 CellChangeTimes->{{3.9795811783516293`*^9, 
  3.9795812087582703`*^9}},ExpressionUUID->"f79936b3-6415-4414-949e-\
fe4a634633c7"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{"pPlus", "-", "pMinus"}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9795811305072002`*^9, 3.979581150366271*^9}, {
   3.987938659312608*^9, 3.9879386701197243`*^9}, {3.9907434666807137`*^9, 
