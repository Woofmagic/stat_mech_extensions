Cell["Just need to check if I can simplify this with another form:", "Text",
 CellChangeTimes->{{3.97957007954552*^9, 
  3.979570085648554*^9}},ExpressionUUID->"771a6a4a-a5a2-4a23-9782-\
45b55fa3e792"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[Alpha]", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"Log", "[", 
         RowBox[{"\[Beta]", " ", "\[Sigma]"}], "]"}], "-", 
        RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
          RowBox[{"\[Alpha]", " ", "\[Sigma]"}]}], "]"}]}], ")"}]}], "+", 
     RowBox[{"\[Gamma]", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"Log", "[", 
         RowBox[{"\[Delta]", " ", "\[Sigma]"}], "]"}], "-", 
        RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
          RowBox[{"\[Gamma]", " ", "\[Sigma]"}]}], "]"}]}], ")"}]}]}], " ", 
    ")"}], "-", "LVEnergyAverage"}], "//", "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.979570087344699*^9, 3.979570160694601*^9}, {
  3.988448536469624*^9, 3.9884485406567707`*^9}},
 CellLabel->
  "In[210]:=",ExpressionUUID->"da2b2f99-4142-4f11-a080-209fb2575731"]
}, Open  ]],

