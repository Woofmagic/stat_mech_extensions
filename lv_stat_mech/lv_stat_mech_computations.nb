Probability Distribution:", "Section",
 CellChangeTimes->{{3.988453238509432*^9, 3.9884532413503027`*^9}, 
   3.988453499677051*^9, {3.9884535453825397`*^9, 
   3.988453551990052*^9}},ExpressionUUID->"a9971534-effd-427d-a286-\
a3c076e2da23"],

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"cp", " ", 
    RowBox[{"LVZp", "[", "\[Sigma]", "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"p", ",", 
     RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
