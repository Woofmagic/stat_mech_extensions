      RowBox[{"PolyGamma", "[", 
       RowBox[{"0", ",", 
        FractionBox["\[Gamma]", "T"]}], "]"}]}]}], ",", 
    RowBox[{"T", "->", "0"}], ",", 
    RowBox[{"Direction", "->", 
     RowBox[{"-", "1"}]}]}], "]"}], "-", 
  RowBox[{"Limit", "[", 
