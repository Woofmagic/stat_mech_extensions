     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"Exp", "[", "x", "]"}], "+", "x"}], "]"}]}], "]"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"x", "\[Element]", "PositiveReals"}]}]}], "]"}]], "Input",
