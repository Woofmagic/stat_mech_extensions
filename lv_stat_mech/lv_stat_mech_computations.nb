Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"ConstE", "==", 
     RowBox[{
      RowBox[{"\[Gamma]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Exp", "[", "p", "]"}], "-", "p"}], ")"}]}], " ", "+", " ", 
      RowBox[{"\[Alpha]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Exp", "[", "q", "]"}], "-", "q"}], ")"}]}]}]}], ",", "p"}], 
   "]"}], "]"}]], "Input",
