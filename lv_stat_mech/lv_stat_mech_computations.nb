1afb43e9a2d1"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"(", 
    FractionBox[
     RowBox[{"\[Alpha]", "+", "\[Gamma]", "+", 
      RowBox[{"T", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Log", "[", 
          RowBox[{"Gamma", "[", 
           FractionBox["\[Alpha]", "T"], "]"}], "]"}], "+", 
         RowBox[{"Log", "[", 
          RowBox[{"Gamma", "[", 
           FractionBox["\[Gamma]", "T"], "]"}], "]"}]}], ")"}]}], "-", 
      RowBox[{"\[Alpha]", " ", 
       RowBox[{"PolyGamma", "[", 
        RowBox[{"0", ",", 
         FractionBox["\[Alpha]", "T"]}], "]"}]}], "-", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"PolyGamma", "[", 
        RowBox[{"0", ",", 
         FractionBox["\[Gamma]", "T"]}], "]"}]}]}], "T"], ")"}], "-", 
   RowBox[{"(", 
    RowBox[{"LVEntropy", "/.", 
     RowBox[{"\[Sigma]", "->", 
      FractionBox["1", "T"]}]}], ")"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.9884754103407583`*^9, 3.98847554926422*^9}, {
