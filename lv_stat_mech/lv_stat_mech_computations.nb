Cell[CellGroupData[{

Cell["\<\
(#3.5.1.3): If the Entropy crosses 0 at some finite T, we should be able to \
figure out where that is:\
\>", "Subsubsection",
 CellChangeTimes->{{3.98847717705931*^9, 
  3.988477194181676*^9}},ExpressionUUID->"ff03775a-594d-4ebe-91a1-\
f79cccee3fb8"],

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"\[Alpha]", "+", "\[Gamma]", "+", 
       RowBox[{"\[Gamma]", " ", 
        RowBox[{"Log", "[", 
         FractionBox["\[Delta]", "T"], "]"}]}]}], "T"], "+", 
     RowBox[{"Log", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["\[Delta]", "T"], ")"}], 
        RowBox[{"-", 
         FractionBox["\[Gamma]", "T"]}]], " ", 
       RowBox[{"Gamma", "[", 
        FractionBox["\[Alpha]", "T"], "]"}], " ", 
       RowBox[{"Gamma", "[", 
        FractionBox["\[Gamma]", "T"], "]"}]}], "]"}], "-", 
     FractionBox[
      RowBox[{
       RowBox[{"\[Alpha]", " ", 
        RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
          FractionBox["\[Alpha]", "T"]}], "]"}]}], "+", 
       RowBox[{"\[Gamma]", " ", 
        RowBox[{"PolyGamma", "[", 
         RowBox[{"0", ",", 
          FractionBox["\[Gamma]", "T"]}], "]"}]}]}], "T"]}], "==", "0"}], ",", 
   RowBox[{"{", "T", "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988477202732119*^9, 3.9884773145460043`*^9}, {
  3.992104549573038*^9, 
  3.9921045499535513`*^9}},ExpressionUUID->"93325d41-871c-4111-a9c3-\
fead3d2b9757"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Reduce", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"\[Alpha]", "+", "\[Gamma]", "+", 
        RowBox[{"\[Gamma]", " ", 
         RowBox[{"Log", "[", 
          FractionBox["\[Delta]", "T"], "]"}]}]}], "T"], "+", 
      RowBox[{"Log", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox["\[Delta]", "T"], ")"}], 
         RowBox[{"-", 
          FractionBox["\[Gamma]", "T"]}]], " ", 
        RowBox[{"Gamma", "[", 
         FractionBox["\[Alpha]", "T"], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         FractionBox["\[Gamma]", "T"], "]"}]}], "]"}], "-", 
      FractionBox[
       RowBox[{
        RowBox[{"\[Alpha]", " ", 
         RowBox[{"PolyGamma", "[", 
          RowBox[{"0", ",", 
           FractionBox["\[Alpha]", "T"]}], "]"}]}], "+", 
        RowBox[{"\[Gamma]", " ", 
         RowBox[{"PolyGamma", "[", 
          RowBox[{"0", ",", 
           FractionBox["\[Gamma]", "T"]}], "]"}]}]}], "T"]}], "==", "0"}], 
    ",", 
    RowBox[{"{", "T", "}"}]}], "]"}], "\n"}]], "Input",
 CellChangeTimes->{{3.988477324652958*^9, 3.9884773339387083`*^9}, {
  3.988477368128263*^9, 3.988477416197294*^9}, {3.988477555018342*^9, 
  3.9884775948537493`*^9}, {3.992104556287314*^9, 
  3.99210455800704*^9}},ExpressionUUID->"d757d416-2f6e-4ee9-969e-\
e66f513172e6"],

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[Alpha]", "+", "\[Gamma]", "+", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"Log", "[", 
        FractionBox["\[Delta]", "T"], "]"}]}]}], "T"], "+", 
    RowBox[{"Log", "[", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["\[Delta]", "T"], ")"}], 
       RowBox[{"-", 
        FractionBox["\[Gamma]", "T"]}]], " ", 
      RowBox[{"Gamma", "[", 
       FractionBox["\[Alpha]", "T"], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       FractionBox["\[Gamma]", "T"], "]"}]}], "]"}], "-", 
    FractionBox[
     RowBox[{
      RowBox[{"\[Alpha]", " ", 
       RowBox[{"PolyGamma", "[", 
        RowBox[{"0", ",", 
         FractionBox["\[Alpha]", "T"]}], "]"}]}], "+", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"PolyGamma", "[", 
        RowBox[{"0", ",", 
         FractionBox["\[Gamma]", "T"]}], "]"}]}]}], "T"]}], ",", 
   RowBox[{"{", 
    RowBox[{"T", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988477428783845*^9, 3.988477472259713*^9}},
 CellLabel->
  "In[458]:=",ExpressionUUID->"5e34dd68-55cd-4234-8317-155b36ee03da"]
