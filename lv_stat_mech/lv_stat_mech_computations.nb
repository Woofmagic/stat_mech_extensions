Cell[CellGroupData[{

Cell["\<\
(#2.2): Suppose it\[CloseCurlyQuote]s an \[OpenCurlyDoubleQuote]ecological \
ideal gas,\[CloseCurlyDoubleQuote] where no q is featured in H:\
\>", "Section",
 CellChangeTimes->{{3.987867470465252*^9, 
  3.9878674840193167`*^9}},ExpressionUUID->"096fe50f-d843-469f-99ea-\
cd9ce70c8a17"],

Cell["\<\
We pretend that, just for computation\[CloseCurlyQuote]s sake, that there is \
no q in the Hamiltonian, or rather that q only ranges from 0 to some fixed \
\[OpenCurlyDoubleQuote]box\[CloseCurlyDoubleQuote] size of length L.\
\>", "Text",
 CellChangeTimes->{{3.987939512161786*^9, 3.987939539042253*^9}, 
   3.989069369855678*^9},ExpressionUUID->"77f2f247-1ffb-4c78-a17f-\
7c5909744f98"],

Cell[CellGroupData[{

Cell["\<\
(#2.2.1): Solving for the maximum value p can take with a fixed E:\
\>", "Subsection",
 CellChangeTimes->{{3.98793950353974*^9, 3.9879395106453953`*^9}, {
  3.987939541405795*^9, 
  3.987939549838625*^9}},ExpressionUUID->"511be022-b827-46e9-8f10-\
c55ffd13f895"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"ConstE", "==", 
    RowBox[{
     RowBox[{"\[Delta]", " ", 
      RowBox[{"Exp", "[", "p", "]"}]}], "-", 
     RowBox[{"\[Gamma]", " ", "p"}]}]}], " ", ",", "p"}], "]"}]], "Input",
 CellChangeTimes->{{3.9878674949662533`*^9, 3.987867502044139*^9}, {
   3.987939184027935*^9, 3.9879391874425983`*^9}, {3.9918645055481043`*^9, 
   3.991864530950248*^9}, 3.992104353402299*^9},
 CellLabel->"In[47]:=",ExpressionUUID->"1217037e-6bfc-45bf-8f5a-70a306bb9803"],

Cell[BoxData[
 TemplateBox[{
  "Solve", "nsmet", 
   "\"This system cannot be solved with the methods available to Solve. Try \
Reduce or FindInstance instead.\"", 2, 47, 6, 31502616698114708966, "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellChangeTimes->{3.9921774799471407`*^9},
 CellLabel->
  "During evaluation of \
In[47]:=",ExpressionUUID->"3adcccad-8770-433d-b01e-ac9b6ce1b488"],

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"ConstE", "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "p"}], " ", "\[Gamma]"}], "+", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", "p"], " ", "\[Delta]"}]}]}], ",", 
   "p"}], "]"}]], "Output",
 CellChangeTimes->{3.9921774799578047`*^9},
 CellLabel->"Out[47]=",ExpressionUUID->"04eebc3e-d154-40eb-b292-e049654ef1dc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["(#2.2.1.1): Verifying the upper bound is correct:", "Subsubsection",
 CellChangeTimes->{{3.9879395527757607`*^9, 
  3.987939569535124*^9}},ExpressionUUID->"73aa5e8d-e355-4854-9103-\
8781fb7dca7d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Delta]", " ", 
     RowBox[{"Exp", "[", "p", "]"}]}], "-", 
    RowBox[{"\[Gamma]", " ", "p"}]}], " ", "/.", 
   RowBox[{"p", "->", 
    FractionBox[
     RowBox[{
      RowBox[{"-", "ConstE"}], "-", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"0", ",", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"-", 
              FractionBox["ConstE", "\[Gamma]"]}]], " ", "\[Delta]"}], 
           "\[Gamma]"]}]}], "]"}]}]}], "\[Gamma]"]}]}], "//", 
  "Simplify"}]], "Input",
 CellChangeTimes->{{3.987939151407981*^9, 3.987939202848134*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"acce70be-691b-4801-b932-2462c6e589ed"],

