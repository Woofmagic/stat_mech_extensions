Cell["Doing the integral hinged upon the following identity:", "Text",
 CellChangeTimes->{{3.990804328849243*^9, 
  3.990804335206555*^9}},ExpressionUUID->"e7b295f1-ab26-421d-8992-\
624a5e2a377b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ProductLog", "[", 
    RowBox[{"0", ",", 
     RowBox[{"x", " ", 
      RowBox[{"Exp", "[", "x", "]"}]}]}], "]"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"x", "\[Element]", "PositiveReals"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.990799352768346*^9, 3.990799395458836*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"04da3fd9-1cb6-4192-810c-05dd6e60f648"],

Cell[BoxData["x"], "Output",
 CellChangeTimes->{3.99217747963376*^9},
 CellLabel->"Out[36]=",ExpressionUUID->"d8aa5756-0a75-48a8-886f-d01a683c46f8"]
}, Open  ]],

Cell["\<\
From the Wikipedia page: \
https://en.wikipedia.org/wiki/Lambert_W_function#Identities
Since f(x) = xex is not injective, it does not always hold that W(f(x)) = x, \
much like with the inverse trigonometric functions. \
\>", "Text",
 CellChangeTimes->{{3.990799455640506*^9, 
  3.990799463488016*^9}},ExpressionUUID->"2fea774e-4306-46a8-90f0-\
6cc5ec9da6bd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ProductLog", "[", 
    RowBox[{"0", ",", 
     RowBox[{"Exp", "[", 
      RowBox[{"x", " ", 
       RowBox[{"Exp", "[", "x", "]"}]}], "]"}]}], "]"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"x", "\[Element]", "PositiveReals"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.990799404276458*^9, 3.99079940486287*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"ed1126f9-fe65-4683-bc7f-be6faafad58d"],

Cell[BoxData[
 RowBox[{"ProductLog", "[", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", "x"], " ", "x"}]], "]"}]], "Output",
 CellChangeTimes->{3.992177479648217*^9},
 CellLabel->"Out[37]=",ExpressionUUID->"1e13b36b-9f68-4c4c-b81d-2c3ab6acbaf9"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"ConstE", "-", 
         RowBox[{
          SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "+", 
         RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{"-", "ConstE"}], "\[Gamma]"], "]"}], 
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "-", 
        RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"], "]"}]}]}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"\[Alpha]", "\[Element]", "PositiveReals"}], "&&", 
     RowBox[{"\[Gamma]", "\[Element]", "PositiveReals"}]}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.990804355149249*^9, 3.9908043851988897`*^9}, {
  3.990898881473971*^9, 3.990898893696027*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"32e3c8d4-259e-47fc-a26f-a1930835b12b"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.992177479663136*^9},
 CellLabel->"Out[38]=",ExpressionUUID->"f2cbd4ff-9c3d-408e-a86e-b11c3c681230"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"ConstE", "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "+", 
        RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"Exp", "[", 
     FractionBox[
      RowBox[{"-", "ConstE"}], "\[Gamma]"], "]"}], 
    RowBox[{"Exp", "[", 
     RowBox[{
      FractionBox["\[Alpha]", "\[Gamma]"], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", "q"], " ", "-", "q"}], ")"}]}], " ",
      "]"}]}]}], "//", "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.990806004460539*^9, 3.9908060254801903`*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"71427a2f-8426-476c-9b61-1a556f695a91"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.992177479676731*^9},
 CellLabel->"Out[39]=",ExpressionUUID->"a49dd49f-81e8-4f6e-acec-a8a3664f7907"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"ConstE", "-", 
         RowBox[{
          SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "+", 
         RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{"-", "ConstE"}], "\[Gamma]"], "]"}], 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{"Exp", "[", 
         FractionBox["\[Alpha]", "\[Gamma]"], "]"}], "]"}], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", "q"], " ", "-", "q"}], ")"}]}], 
      " ", "]"}]}]}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"\[Alpha]", "\[Element]", "PositiveReals"}], "&&", 
     RowBox[{"\[Gamma]", "\[Element]", "PositiveReals"}]}]}]}], 
