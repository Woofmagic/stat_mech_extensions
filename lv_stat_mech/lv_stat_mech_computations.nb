     SubscriptBox["k", "B"], "(", 
     RowBox[{
      RowBox[{"\[Beta]", " ", 
       RowBox[{"\[LeftAngleBracket]", "E", "\[RightAngleBracket]"}]}], " ", 
      "+", " ", 
      RowBox[{"ln", "(", "Z", ")"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"3a51ad6e-02c9-4d28-8f42-8720c96587a9"]
}], "Text",
 CellChangeTimes->{{3.979573311214548*^9, 3.9795733369641533`*^9}, {
