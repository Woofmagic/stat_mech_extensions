Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[Alpha]", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"Log", "[", 
         RowBox[{"\[Beta]", " ", "\[Theta]"}], "]"}], "-", 
