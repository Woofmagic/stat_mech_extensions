Cell[CellGroupData[{

Cell["(#2.3.2): Trying to Solve for the Bounding Functions:", "Subsection",
 CellChangeTimes->{
  3.990276704461771*^9, {3.990276776390271*^9, 3.990276786820125*^9}, {
   3.990277061689472*^9, 
   3.9902770617461348`*^9}},ExpressionUUID->"ad9ffb54-e91e-4bb7-a15f-\
7dca8070b5ab"],

Cell[CellGroupData[{

Cell["\<\
(#2.3.2.1): Seeing how many Solutions are found for the Implicit Equation:\
\>", "Subsubsection",
 CellChangeTimes->{{3.979580799195891*^9, 3.979580813718585*^9}, {
  3.990277062832979*^9, 
  3.990277062906725*^9}},ExpressionUUID->"dd0781b1-6070-43bf-9e55-\
512240002a3d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"ConstE", "==", 
     RowBox[{
      RowBox[{"\[Delta]", " ", 
       SuperscriptBox["p", "2"]}], "+", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"Exp", "[", "q", "]"}]}], "-", 
      RowBox[{"\[Alpha]", " ", "q"}]}]}], ",", "p"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9787164165407143`*^9, 3.978716517425126*^9}, {
   3.978716598636434*^9, 3.978716626713106*^9}, {3.9787857473731422`*^9, 
   3.978785747526458*^9}, {3.9787866533566017`*^9, 3.978786664561541*^9}, {
   3.979580739096911*^9, 3.9795807778709793`*^9}, {3.987938444883279*^9, 
   3.987938449860599*^9}, 3.990276888930666*^9, {3.9921044088854322`*^9, 
   3.992104409693869*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"22bf1de8-fa46-4fc8-9d1d-1d8c869437c4"],

Cell[BoxData[
 TemplateBox[{
  "Solve", "nsmet", 
   "\"This system cannot be solved with the methods available to Solve. Try \
Reduce or FindInstance instead.\"", 2, 58, 7, 31502616698114708966, "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellChangeTimes->{3.9921774810478077`*^9},
 CellLabel->
  "During evaluation of \
In[58]:=",ExpressionUUID->"3c93fee7-e72b-457f-8ad3-355c35736e23"],

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ConstE", "+", 
     RowBox[{"q", " ", "\[Alpha]"}]}], "\[Equal]", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}], "+", 
     RowBox[{
      SuperscriptBox["p", "2"], " ", "\[Delta]"}]}]}], ",", "p"}], 
  "]"}]], "Output",
 CellChangeTimes->{3.992177481159206*^9},
 CellLabel->"Out[58]=",ExpressionUUID->"f616a10e-5db8-4acd-b0e0-20eaaf25e2f9"]
}, Open  ]],

Cell["Let\[CloseCurlyQuote]s now check to see if we get the right results:", \
"Text",
 CellChangeTimes->{{3.990276923668179*^9, 
  3.9902769285673857`*^9}},ExpressionUUID->"63803068-b77c-41ff-848f-\
e2bc63dc9624"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Delta]", " ", 
     SuperscriptBox["p", "2"]}], "+", 
    RowBox[{"\[Beta]", " ", 
     RowBox[{"Exp", "[", "q", "]"}]}], "-", 
    RowBox[{"\[Alpha]", " ", "q"}]}], "/.", 
   RowBox[{"p", "->", 
    RowBox[{"-", 
     FractionBox[
      SqrtBox[
       RowBox[{"ConstE", "+", 
        RowBox[{"q", " ", "\[Alpha]"}], "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}]], 
      SqrtBox["\[Delta]"]]}]}]}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.987938521634659*^9, 3.9879385663542137`*^9}, {
  3.990276897640527*^9, 3.990276915816354*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"1aa3f75a-fc7a-4874-96ad-34d6c0939368"],

Cell[BoxData["ConstE"], "Output",
 CellChangeTimes->{3.992177481180105*^9},
 CellLabel->"Out[59]=",ExpressionUUID->"a5ee154b-7a84-47cc-9d22-0b220906badf"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Delta]", " ", 
     SuperscriptBox["p", "2"]}], "+", 
    RowBox[{"\[Beta]", " ", 
     RowBox[{"Exp", "[", "q", "]"}]}], "-", 
    RowBox[{"\[Alpha]", " ", "q"}]}], "/.", 
   RowBox[{"p", "->", 
    RowBox[{"+", 
     FractionBox[
      SqrtBox[
       RowBox[{"ConstE", "+", 
        RowBox[{"q", " ", "\[Alpha]"}], "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}]], 
      SqrtBox["\[Delta]"]]}]}]}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.9879385777026997`*^9, 3.987938577778433*^9}, 
   3.9902768993039293`*^9, {3.990276936053121*^9, 3.990276938847892*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"624b0c3d-dd1c-4379-bff7-9276e4b6b0bb"],

Cell[BoxData["ConstE"], "Output",
 CellChangeTimes->{3.9921774811927843`*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"9874b8b0-bd24-46be-8fc7-ad2ffbce9f31"]
}, Open  ]],

Cell["\<\
The two solutions differ by the \[PlusMinus] sign, and the momentum is \
squared, so these will of course give the same thing, namely ConstE.\
\>", "Text",
 CellChangeTimes->{{3.987938598167737*^9, 3.987938603347875*^9}, {
  3.9902769425813303`*^9, 
  3.990276961915676*^9}},ExpressionUUID->"0dd1a047-1fd9-4604-b4ce-\
27d593f5e6b9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["(#2.3.2.2): Manually Entering the Solutions We Got:", "Subsubsection",
 CellChangeTimes->{{3.979580820672736*^9, 3.9795808349077806`*^9}, {
  3.9902770645688267`*^9, 
  3.990277064624946*^9}},ExpressionUUID->"aeda633e-db76-4e1b-a471-\
b5f04a52f125"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"microPPlus", "=", 
   FractionBox[
    SqrtBox[
     RowBox[{"ConstE", "+", 
      RowBox[{"q", " ", "\[Alpha]"}], "-", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Beta]"}]}]], 
    SqrtBox["\[Delta]"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"microPMinus", "=", 
   RowBox[{"-", 
    FractionBox[
     SqrtBox[
      RowBox[{"ConstE", "+", 
