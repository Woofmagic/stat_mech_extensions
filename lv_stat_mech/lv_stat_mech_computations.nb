Cell[CellGroupData[{
Cell["\<\
Calculation of Statistical-Mechanical Quantities of Lotka-Volterra Hamiltonian\
\>", "Title",
 CellChangeTimes->{{3.978627177014625*^9, 
  3.978627205752421*^9}},ExpressionUUID->"5a3bd287-bd54-4ca2-a3a9-\
4744b03949c7"],

Cell[CellGroupData[{

Cell["(#0): Pre-notebook Stuff:", "Chapter",
 CellChangeTimes->{{3.992104176728443*^9, 
  3.992104181212434*^9}},ExpressionUUID->"ed6f45f6-94b4-4fb3-9b90-\
ae0405ca553f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T", "\[Element]", "PositiveReals"}], "&&", " ", 
     RowBox[{"(*", " ", "temperature", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"\[Sigma]", "\[Element]", "PositiveReals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"inverse", " ", "temperature"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"ConstE", "\[Element]", "Reals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"the", " ", "\"\<energy\>\""}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"q", "\[Element]", "Reals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"new", " ", "coordinate"}], ",", " ", 
       RowBox[{"generalized", " ", "position"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"p", "\[Element]", "Reals"}], "&&", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"new", " ", "coordinate"}], ",", " ", 
       RowBox[{"conjugate", " ", "momentum"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]", "\[Element]", "PositiveReals"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Beta]", "\[Element]", "PositiveReals"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Gamma]", "\[Element]", "PositiveReals"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Delta]", "\[Element]", "PositiveReals"}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9921041846409197`*^9, 3.9921042829246483`*^9}},
 CellLabel->
  "In[132]:=",ExpressionUUID->"46fd515b-7c4d-44e7-a5eb-3223feb80d70"]
}, Open  ]],

