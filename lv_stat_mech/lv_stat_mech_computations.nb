 RowBox[{"Plot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"LVZIntegral", "/.", 
       RowBox[{"\[Alpha]", "->", 
        FractionBox["2", "3"]}]}], "/.", 
      RowBox[{"\[Beta]", "->", 
       FractionBox["4", "3"]}]}], "/.", 
     RowBox[{"\[Gamma]", "->", "1"}]}], "/.", 
    RowBox[{"\[Delta]", "->", "1"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"\[Sigma]", ",", "0", ",", "20"}], "}"}], ",", 
   "\[IndentingNewLine]", 
