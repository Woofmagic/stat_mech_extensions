822567139e21"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Series", "[", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "ConstE"}], "-", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"1", ",", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"-", 
              FractionBox["ConstE", "\[Gamma]"]}]], " ", "\[Delta]"}], 
           "\[Gamma]"]}]}], "]"}]}]}], "\[Gamma]"], ",", 
    RowBox[{"{", 
     RowBox[{"ConstE", ",", "0", ",", "1"}], "}"}]}], "]"}], "//", 
  "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.987939456309514*^9, 3.9879394687664537`*^9}, {
  3.989069386384012*^9, 3.989069386472289*^9}},
