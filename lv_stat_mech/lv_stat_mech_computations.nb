  "]"}]], "Input",
 CellChangeTimes->{{3.9907436693700647`*^9, 3.9907437152371693`*^9}, {
   3.990743907585285*^9, 3.990743911425949*^9}, {3.990743947105583*^9, 
   3.990743949667263*^9}, {3.9907899045375757`*^9, 3.990789910085935*^9}, 
   3.990804151130166*^9, {3.9917777801451063`*^9, 3.991777793156769*^9}, 
   3.9921043415835447`*^9},
 CellLabel->"In[31]:=",ExpressionUUID->"ed2602ed-fa32-4e36-aa41-e4eb0fdfe6f5"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "5", "6"], 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"ProductLog", "[", 
     RowBox[{"-", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"ConstE", "-", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", "q"], " ", "\[Alpha]"}], "+", 
          RowBox[{"q", " ", "\[Alpha]"}]}], "\[Gamma]"]}]]}], "]"}]}], 
   RowBox[{"\[DifferentialD]", "q"}]}]}]], "Output",
