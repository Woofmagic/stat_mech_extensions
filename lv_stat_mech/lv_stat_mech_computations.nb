Cell[CellGroupData[{

Cell["(#2.1.2): Trying to Solve for the Bounding Functions:", "Subsection",
 CellChangeTimes->{
  3.978720655064846*^9, {3.9787891519691677`*^9, 3.978789154337585*^9}, {
   3.978789326927298*^9, 3.978789329039371*^9}, {3.979580657697672*^9, 
