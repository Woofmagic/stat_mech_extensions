Cell[CellGroupData[{

Cell[TextData[{
 "(#3.3): Variance of Average Energy, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SuperscriptBox[
      RowBox[{"(", "\[CapitalDelta]E", ")"}], "2"], "\[RightAngleBracket]"}], 
    "=", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{"\[LeftAngleBracket]", "E", "\[RightAngleBracket]"}]}], 
       RowBox[{"\[PartialD]", "\[Beta]"}]]}], "=", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[PartialD]", "2"], 
       RowBox[{"ln", "(", "Z", ")"}]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox["\[Beta]", "2"]}]]}]}], TraditionalForm]], "Section",
  ExpressionUUID->"3ff85f4e-87b2-4e5b-905b-a167dc4af9e1"],
