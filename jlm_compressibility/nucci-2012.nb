    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"r1", "[", "t", "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "r2", "]"}], "[", "t", 
        "]"}]}], "-", 
