        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "r1", "]"}], "[", "t", 
        "]"}]}], "-", 
      RowBox[{"2", " ", "m1", " ", "b", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"r1", "[", "t", "]"}], "]"}]}], "+", 
      RowBox[{"2", " ", "m2", " ", "B", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"r2", "[", "t", "]"}], "]"}]}], "+", 
