Notebook[{

Cell[CellGroupData[{
Cell["\<\
Nucci-2012: Lagrangians for Biological Models \
(https://doi.org/10.1142/S1402925112500210)\
\>", "Title",
 CellChangeTimes->{{3.990217862275579*^9, 3.990217871672862*^9}, {
  3.990219366183927*^9, 
  3.9902193803415937`*^9}},ExpressionUUID->"cfec5e9a-a400-4593-a4e1-\
454d4e481c09"],

Cell[TextData[{
 "The main point of this short notebook is to verify that an argument made in \
this paper is not sound. The argument is made on page 6:  \
\[OpenCurlyDoubleQuote]We note that [the LV equations] are autonomous and \
therefore invariant under time translation, namely ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "t"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fedb862a-77f7-4436-8dd2-0902a0877a06"],
 ". It is easy to show that the Lagrangian ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", 
    RowBox[{"[", "w", "]"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6206a39d-3af8-4cba-afd5-b44709df1813"],
 " in (24) yields a time-invariant first integral through Noether\
\[CloseCurlyQuote]s theorem [15]...\[CloseCurlyDoubleQuote] The issue is the \
following: we must not conflate autonomous dynamics with time-invariant first \
integrals obtained with the Noether procedure. It is only that the Lagrangian \
for the LV system, once obtained, is explicitly time-independent that we have \
a conserved charge after effecting infinitesimal time translation. The \
Gompertz and Verhulst models are autonomous, continuous-time, two-dimensional \
dynamical systems, just like the LV system, but their Lagrangians---as \
obtained via the method of the Jacobi Last Multiplier---are explicitly \
time-dependent, and thus Noether\[CloseCurlyQuote]s procedure will not yield \
any conserved charge."
}], "Subtitle",
 CellChangeTimes->{{3.990219136479846*^9, 3.990219150292721*^9}, {
  3.990219192872212*^9, 
  3.990219336695524*^9}},ExpressionUUID->"60011b90-d352-4347-8166-\
6c77c740731f"],

Cell[CellGroupData[{

Cell["(#1): Lotka-Volterra Model:", "Chapter",
 CellChangeTimes->{{3.990218003903257*^9, 3.990218011000128*^9}, {
  3.99021833341712*^9, 
  3.990218333631913*^9}},ExpressionUUID->"2656d250-0b1a-43a9-8bc7-\
35315e705abc"],

Cell[CellGroupData[{

Cell["(#1.1): Dynamical Equations:", "Section",
 CellChangeTimes->{{3.990218014075122*^9, 3.990218022563631*^9}, {
  3.9902183344057217`*^9, 
  3.990218334459448*^9}},ExpressionUUID->"9ab2b780-09b3-4c2d-9eb0-\
1d976d16e9e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LVDynamicalSystem", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "1", "]"}], "[", "r1", "]"}], "[", "t", 
       "]"}], "->", 
      RowBox[{
       RowBox[{"b", " ", 
        RowBox[{"Exp", "[", "r2", "]"}]}], "+", "a"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "1", "]"}], "[", "r2", "]"}], "[", "t", 
       "]"}], "->", 
      RowBox[{
       RowBox[{"B", " ", 
        RowBox[{"Exp", "[", "r1", "]"}]}], "+", "A"}]}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.990218025677373*^9, 3.990218044268899*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"c727ef96-8948-4c83-adda-ee9b426dc6a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["(#1.2): Nucci\[CloseCurlyQuote]s Lagrangian Eq. (2):", "Section",
 CellChangeTimes->{{3.990218048343115*^9, 3.990218056656662*^9}, {
  3.990218335428369*^9, 
  3.990218335482304*^9}},ExpressionUUID->"ea93e18d-9a48-4766-b680-\
0031523a5489"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LVLagrangianRVariable", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"r1", "[", "t", "]"}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "r2", "]"}], "[", "t", 
      "]"}]}], "-", 
    RowBox[{
     RowBox[{"r2", "[", "t", "]"}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "r1", "]"}], "[", "t", 
      "]"}]}], "+", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "B"}], " ", 
        RowBox[{"Exp", "[", "r1", "]"}]}], "+", 
       RowBox[{"b", " ", 
        RowBox[{"Exp", "[", "r2", "]"}]}], "-", 
       RowBox[{"A", " ", "r1"}], "+", 
       RowBox[{"a", " ", "r2"}]}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.990218059465591*^9, 3.990218065500347*^9}, {
  3.99021815427671*^9, 3.990218189767086*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"a7cf9e0a-7ca6-444c-8648-bfe2e0e0bcd4"]
}, Open  ]],

