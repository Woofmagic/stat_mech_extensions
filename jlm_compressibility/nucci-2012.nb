Cell[CellGroupData[{

Cell["(#2.3.2): Total Derivative of Noether Charge:", "Subsection",
 CellChangeTimes->{{3.9902179590942698`*^9, 3.990217968269014*^9}, {
  3.990218346661613*^9, 
  3.9902183467170267`*^9}},ExpressionUUID->"cca2a5ab-67eb-4d1d-8c1f-\
5f7652ba37e5"],

Cell[TextData[{
 "We are making the same argument as Nucci earlier: the dynamics are \
time-invariant, and so there ought to be a conserved charge when we make an \
infinitesimal time translation. Obviously, that is not what is present in the \
Lagrangian that Nucci derived, but that was the argument offered on page 6: \
\[OpenCurlyDoubleQuote]We note that [the LV equations] are autonomous and \
therefore invariant under time translation, namely ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "t"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3f0ccae8-4c39-49d5-9e14-005f754c651d"],
 ". It is easy to show that the Lagrangian ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", 
    RowBox[{"[", "w", "]"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "654a2b37-54f6-496b-a629-0a7e8f9e5352"],
 " in (24) yields a time-invariant first integral through Noether\
\[CloseCurlyQuote]s theorem [15]...\[CloseCurlyDoubleQuote]"
}], "Text",
 CellChangeTimes->{{3.990218671331168*^9, 
  3.990218778462614*^9}},ExpressionUUID->"ce403538-1b34-4fcd-8218-\
795c2bd34bbc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{"GompertzNoetherCharge", ",", "t"}], "]"}], "/.", " ", 
    "GompertzDynamicalSystem"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"b", "\[Element]", "Reals"}], "&&", 
     RowBox[{"B", "\[Element]", "Reals"}], "&&", 
     RowBox[{"a", "\[Element]", "Reals"}], "&&", 
     RowBox[{"A", "\[Element]", "Reals"}], "&&", 
     RowBox[{"m1", "\[Element]", "Reals"}], "&&", 
     RowBox[{"m2", "\[Element]", "Reals"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9902179698331213`*^9, 3.99021797865305*^9}, {
  3.990218092844041*^9, 3.9902181213957033`*^9}, {3.9902183847984543`*^9, 
  3.9902184157812967`*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"d0d8b210-8290-4f03-bcc6-4fe13a47fcc6"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"-", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "A"}], ")"}], " ", "t"}], ")"}]}]], " ", 
  RowBox[{"(", 
